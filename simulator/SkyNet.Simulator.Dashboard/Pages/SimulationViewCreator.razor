@page "/sim/{SimId}/creator"

@using System.Text.Json
@using Microsoft.JSInterop
@using SkyNet.Simulator.Contracts
@using SkyNet.Simulator.Dashboard.Components
@using SkyNet.Simulator.Dashboard.Services

@inject SimulationViewLayoutStore LayoutStore
@inject IJSRuntime Js

<PageTitle>View Creator</PageTitle>

<h1>View Creator</h1>
<p>
	<b>SimId:</b> <code>@SimId</code>
	|
	<a href="@($"/sim/{Uri.EscapeDataString(SimId)}")">Back to simulation</a>
</p>

@if (!SupportsLayoutEditor)
{
	<p>This creator currently supports <code>tank-transfer</code> and <code>grain-dryer</code>.</p>
}
else
{
	<p>Tune schematic spacing by dragging equipment cards or editing coordinates directly, then save to apply in the live simulation view.</p>

	<h2>Layout Canvas</h2>
	<p class="text-muted">Click and drag equipment cards inside the canvas. Tank transfer keeps shared top and bottom rows aligned; grain dryer moves each module independently.</p>
	<div
		@ref="_editorCanvas"
		class="layout-editor-canvas"
		style="width: @(CurrentCanvasWidth.ToString("0.#"))px; height: @(CurrentCanvasHeight.ToString("0.#"))px;"
		@onpointermove="OnCanvasPointerMoveAsync"
		@onpointerup="EndDrag"
		@onpointerleave="EndDrag"
		@onpointercancel="EndDrag">
		@foreach (var box in EditorBoxes)
		{
			<div class="layout-drag-box @(_draggingBox == box.Id ? "is-dragging" : string.Empty)"
				style="left: @(box.X.ToString("0.#"))px; top: @(box.Y.ToString("0.#"))px; width: @(box.Width.ToString("0.#"))px; min-height: @(box.Height.ToString("0.#"))px;"
				@onpointerdown="e => OnPointerDownAsync(box.Id, e)"
				@onpointerdown:preventDefault="true">
				<div class="layout-drag-box-title">@box.Title</div>
				<div class="layout-drag-box-sub">@box.Subtitle</div>
			</div>
		}
	</div>

	@if (IsTankTransfer)
	{
		<div style="display:grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 0.75rem; max-width: 980px;">
			<div>
				<label class="form-label">Canvas width</label>
				<input class="form-control form-control-sm" type="number" step="1" @bind="_tankTransferLayout.CanvasWidth" />
			</div>
			<div>
				<label class="form-label">Canvas height</label>
				<input class="form-control form-control-sm" type="number" step="1" @bind="_tankTransferLayout.CanvasHeight" />
			</div>
			<div>
				<label class="form-label">Box width</label>
				<input class="form-control form-control-sm" type="number" step="1" @bind="_tankTransferLayout.BoxWidth" />
			</div>
			<div>
				<label class="form-label">Top row Y</label>
				<input class="form-control form-control-sm" type="number" step="1" @bind="_tankTransferLayout.TopRowY" />
			</div>
			<div>
				<label class="form-label">Bottom row Y</label>
				<input class="form-control form-control-sm" type="number" step="1" @bind="_tankTransferLayout.BottomRowY" />
			</div>
			<div>
				<label class="form-label">Blower X</label>
				<input class="form-control form-control-sm" type="number" step="1" @bind="_tankTransferLayout.BlowerX" />
			</div>
			<div>
				<label class="form-label">Airlock X</label>
				<input class="form-control form-control-sm" type="number" step="1" @bind="_tankTransferLayout.AirlockX" />
			</div>
			<div>
				<label class="form-label">Blowline X</label>
				<input class="form-control form-control-sm" type="number" step="1" @bind="_tankTransferLayout.BlowlineX" />
			</div>
			<div>
				<label class="form-label">Source tank X</label>
				<input class="form-control form-control-sm" type="number" step="1" @bind="_tankTransferLayout.SourceX" />
			</div>
			<div>
				<label class="form-label">Destination tank X</label>
				<input class="form-control form-control-sm" type="number" step="1" @bind="_tankTransferLayout.DestinationX" />
			</div>
			<div>
				<label class="form-label">Equip top anchor Y</label>
				<input class="form-control form-control-sm" type="number" step="1" @bind="_tankTransferLayout.EquipmentTopAnchorY" />
			</div>
			<div>
				<label class="form-label">Equip mid anchor Y</label>
				<input class="form-control form-control-sm" type="number" step="1" @bind="_tankTransferLayout.EquipmentMidAnchorY" />
			</div>
			<div>
				<label class="form-label">Tank bottom anchor Y</label>
				<input class="form-control form-control-sm" type="number" step="1" @bind="_tankTransferLayout.TankBottomAnchorY" />
			</div>
			<div>
				<label class="form-label">Dest inlet anchor Y</label>
				<input class="form-control form-control-sm" type="number" step="1" @bind="_tankTransferLayout.DestinationInletAnchorY" />
			</div>
			<div>
				<label class="form-label">Dest inlet offset X</label>
				<input class="form-control form-control-sm" type="number" step="1" @bind="_tankTransferLayout.DestinationInletOffsetX" />
			</div>
		</div>
	}
	else if (IsGrainDryer)
	{
		<div style="display:grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 0.75rem; max-width: 1180px;">
			<div><label class="form-label">Canvas width</label><input class="form-control form-control-sm" type="number" step="1" @bind="_grainDryerLayout.CanvasWidth" /></div>
			<div><label class="form-label">Canvas height</label><input class="form-control form-control-sm" type="number" step="1" @bind="_grainDryerLayout.CanvasHeight" /></div>
			<div><label class="form-label">Wet bin X</label><input class="form-control form-control-sm" type="number" step="1" @bind="_grainDryerLayout.WetBinX" /></div>
			<div><label class="form-label">Wet bin Y</label><input class="form-control form-control-sm" type="number" step="1" @bind="_grainDryerLayout.WetBinY" /></div>
			<div><label class="form-label">Dryer X</label><input class="form-control form-control-sm" type="number" step="1" @bind="_grainDryerLayout.DryerColumnX" /></div>
			<div><label class="form-label">Dryer Y</label><input class="form-control form-control-sm" type="number" step="1" @bind="_grainDryerLayout.DryerColumnY" /></div>
			<div><label class="form-label">Dry bin X</label><input class="form-control form-control-sm" type="number" step="1" @bind="_grainDryerLayout.DryBinX" /></div>
			<div><label class="form-label">Dry bin Y</label><input class="form-control form-control-sm" type="number" step="1" @bind="_grainDryerLayout.DryBinY" /></div>
			<div><label class="form-label">Filter X</label><input class="form-control form-control-sm" type="number" step="1" @bind="_grainDryerLayout.FilterBoxX" /></div>
			<div><label class="form-label">Filter Y</label><input class="form-control form-control-sm" type="number" step="1" @bind="_grainDryerLayout.FilterBoxY" /></div>
			<div><label class="form-label">Exhaust X</label><input class="form-control form-control-sm" type="number" step="1" @bind="_grainDryerLayout.ExhaustBoxX" /></div>
			<div><label class="form-label">Exhaust Y</label><input class="form-control form-control-sm" type="number" step="1" @bind="_grainDryerLayout.ExhaustBoxY" /></div>
			<div><label class="form-label">Fan module X</label><input class="form-control form-control-sm" type="number" step="1" @bind="_grainDryerLayout.FanModuleX" /></div>
			<div><label class="form-label">Fan module Y</label><input class="form-control form-control-sm" type="number" step="1" @bind="_grainDryerLayout.FanModuleY" /></div>
			<div><label class="form-label">Feed screw X</label><input class="form-control form-control-sm" type="number" step="1" @bind="_grainDryerLayout.FeedScrewX" /></div>
			<div><label class="form-label">Feed screw Y</label><input class="form-control form-control-sm" type="number" step="1" @bind="_grainDryerLayout.FeedScrewY" /></div>
			<div><label class="form-label">Burner module X</label><input class="form-control form-control-sm" type="number" step="1" @bind="_grainDryerLayout.BurnerModuleX" /></div>
			<div><label class="form-label">Burner module Y</label><input class="form-control form-control-sm" type="number" step="1" @bind="_grainDryerLayout.BurnerModuleY" /></div>
			<div><label class="form-label">Feed module X</label><input class="form-control form-control-sm" type="number" step="1" @bind="_grainDryerLayout.FeedModuleX" /></div>
			<div><label class="form-label">Feed module Y</label><input class="form-control form-control-sm" type="number" step="1" @bind="_grainDryerLayout.FeedModuleY" /></div>
			<div><label class="form-label">Discharge X</label><input class="form-control form-control-sm" type="number" step="1" @bind="_grainDryerLayout.DischargeConveyorX" /></div>
			<div><label class="form-label">Discharge Y</label><input class="form-control form-control-sm" type="number" step="1" @bind="_grainDryerLayout.DischargeConveyorY" /></div>
		</div>
	}

	<div style="display:flex; gap: 0.5rem; margin-top: 0.9rem;">
		<button class="btn btn-sm btn-primary" @onclick="SaveLayout">Save layout</button>
		<button class="btn btn-sm btn-secondary" @onclick="ResetLayout">Reset default</button>
	</div>

	@if (!string.IsNullOrWhiteSpace(_status))
	{
		<p class="text-muted" style="margin-top: 0.5rem;">@_status</p>
	}

	<h2>Preview</h2>
	@if (IsTankTransfer)
	{
		<TankTransferSchematic SimId="@SimId" Snapshot="@_tankTransferPreviewSnapshot" Layout="@_tankTransferLayout" />
	}
	else if (IsGrainDryer)
	{
		<GrainDryerSchematic SimId="@SimId" Snapshot="@_grainDryerPreviewSnapshot" Layout="@_grainDryerLayout" />
	}

	<h2>Layout JSON</h2>
	<pre>@LayoutJson</pre>
}

@code {
	[Parameter] public string SimId { get; set; } = string.Empty;

	private TankTransferSchematicLayout _tankTransferLayout = TankTransferSchematicLayout.Default;
	private GrainDryerSchematicLayout _grainDryerLayout = GrainDryerSchematicLayout.Default;
	private string? _status;
	private string? _draggingBox;
	private ClientRect? _canvasRect;
	private double _dragOffsetX;
	private double _dragOffsetY;
	private ElementReference _editorCanvas;
	private const double TankEditorBoxHeight = 176;

	private bool IsTankTransfer => string.Equals(SimId, "tank-transfer", StringComparison.OrdinalIgnoreCase);
	private bool IsGrainDryer => string.Equals(SimId, "grain-dryer", StringComparison.OrdinalIgnoreCase);
	private bool SupportsLayoutEditor => IsTankTransfer || IsGrainDryer;
	private double CurrentCanvasWidth => IsTankTransfer ? _tankTransferLayout.CanvasWidth : _grainDryerLayout.CanvasWidth;
	private double CurrentCanvasHeight => IsTankTransfer ? _tankTransferLayout.CanvasHeight : _grainDryerLayout.CanvasHeight;

	private readonly TelemetrySnapshot _tankTransferPreviewSnapshot = new(
		SimId: "tank-transfer",
		SchemaVersion: 1,
		Tick: 1200,
		TimeSeconds: 20.0,
		Parameters: new Dictionary<string, double>(StringComparer.OrdinalIgnoreCase)
		{
			["PressureControlEnable"] = 1,
			["BlowerEnable"] = 1,
			["AirlockEnable"] = 1,
			["SourceTankCapacityLb"] = 28000,
			["DestinationTankCapacityLb"] = 30000,
		},
		Signals: new Dictionary<string, double>(StringComparer.OrdinalIgnoreCase)
		{
			["BlowerRunning"] = 1,
			["AirlockRunning"] = 1,
			["SourceTankWeightLb"] = 20000,
			["DestinationTankWeightLb"] = 5000,
			["TransferRateLbPerSec"] = 18,
			["BlowlinePressurePsi"] = 8.2,
			["BlowlinePressureCommandPsi"] = 8,
			["AirlockSpeedHz"] = 18,
			["BlowerMotorPercentFla"] = 64,
			["IsStarved"] = 0,
			["IsFull"] = 0,
		});

	private readonly TelemetrySnapshot _grainDryerPreviewSnapshot = new(
		SimId: "grain-dryer",
		SchemaVersion: 1,
		Tick: 900,
		TimeSeconds: 15.0,
		Parameters: new Dictionary<string, double>(StringComparer.OrdinalIgnoreCase)
		{
			["WetBinWeightLb"] = 120000,
			["DryBinWeightLb"] = 18000,
			["DryBinCapacityLb"] = 160000,
			["DryerHoldUpCapacityLb"] = 32000,
			["StartupAutomationEnable"] = 1,
			["ShutdownAutomationEnable"] = 0,
			["FeedEnable"] = 1,
			["BurnerEnable"] = 1,
			["FanEnable"] = 1,
			["FeedRateCommandLbPerSec"] = 18,
			["BurnerFiringRatePercent"] = 68,
			["FanSpeedPercent"] = 78,
			["TargetOutletMoisturePercent"] = 15,
		},
		Signals: new Dictionary<string, double>(StringComparer.OrdinalIgnoreCase)
		{
			["StartupAutomationActive"] = 1,
			["ShutdownAutomationActive"] = 0,
			["FeedRunning"] = 1,
			["BurnerRunning"] = 1,
			["FanRunning"] = 1,
			["WetBinWeightLb"] = 98000,
			["DryBinWeightLb"] = 42000,
			["GrainHoldUpLb"] = 21000,
			["FeedRateLbPerSec"] = 17.2,
			["DischargeRateLbPerSec"] = 16.4,
			["ResidenceTimeMinutes"] = 18.8,
			["AirflowCfm"] = 8450,
			["PlenumTempF"] = 142.4,
			["ExhaustTempF"] = 116.2,
			["BurnerOutputPercent"] = 66.5,
			["InletMoisturePercent"] = 19.5,
			["OutletMoisturePercent"] = 14.9,
			["MoistureControlErrorPercent"] = -0.1,
			["MoistureRemovalRateLbPerSec"] = 0.68,
			["IsWetBinEmpty"] = 0,
			["IsDryBinFull"] = 0,
			["IsHighTempAlarm"] = 0,
			["IsAirflowLowAlarm"] = 0,
		});

	private string LayoutJson => IsTankTransfer
		? JsonSerializer.Serialize(_tankTransferLayout, new JsonSerializerOptions { WriteIndented = true })
		: JsonSerializer.Serialize(_grainDryerLayout, new JsonSerializerOptions { WriteIndented = true });

	private IReadOnlyList<EditorBox> EditorBoxes => IsTankTransfer
		? BuildTankTransferEditorBoxes()
		: BuildGrainDryerEditorBoxes();

	protected override async Task OnParametersSetAsync()
	{
		if (!SupportsLayoutEditor)
		{
			return;
		}

		if (IsTankTransfer)
		{
			_tankTransferLayout = await LayoutStore.GetTankTransferLayoutAsync(SimId);
		}
		else if (IsGrainDryer)
		{
			_grainDryerLayout = await LayoutStore.GetGrainDryerLayoutAsync(SimId);
		}
	}

	private async Task SaveLayout()
	{
		if (IsTankTransfer)
		{
			await LayoutStore.SetTankTransferLayoutAsync(SimId, _tankTransferLayout);
		}
		else if (IsGrainDryer)
		{
			await LayoutStore.SetGrainDryerLayoutAsync(SimId, _grainDryerLayout);
		}

		_status = $"Saved at {DateTime.Now:T}";
	}

	private async Task ResetLayout()
	{
		if (IsTankTransfer)
		{
			await LayoutStore.ResetTankTransferLayoutAsync(SimId);
			_tankTransferLayout = await LayoutStore.GetTankTransferLayoutAsync(SimId);
		}
		else if (IsGrainDryer)
		{
			await LayoutStore.ResetGrainDryerLayoutAsync(SimId);
			_grainDryerLayout = await LayoutStore.GetGrainDryerLayoutAsync(SimId);
		}

		_status = "Reset to defaults.";
	}

	private async Task OnPointerDownAsync(string boxId, PointerEventArgs e)
	{
		if (!SupportsLayoutEditor)
		{
			return;
		}

		_canvasRect = await Js.InvokeAsync<ClientRect?>("skynetLayoutEditor.getElementClientRect", _editorCanvas);
		if (_canvasRect is null || !TryGetEditorBox(boxId, out var box))
		{
			return;
		}

		_draggingBox = boxId;
		_dragOffsetX = e.ClientX - _canvasRect.Left - box.X;
		_dragOffsetY = e.ClientY - _canvasRect.Top - box.Y;
		_status = null;
	}

	private async Task OnCanvasPointerMoveAsync(PointerEventArgs e)
	{
		if (string.IsNullOrWhiteSpace(_draggingBox) || _canvasRect is null || !TryGetEditorBox(_draggingBox, out var box))
		{
			return;
		}

		var localX = e.ClientX - _canvasRect.Left - _dragOffsetX;
		var localY = e.ClientY - _canvasRect.Top - _dragOffsetY;
		var maxX = Math.Max(0, CurrentCanvasWidth - box.Width);
		var maxY = Math.Max(0, CurrentCanvasHeight - box.Height);

		UpdateBoxPosition(_draggingBox, Math.Clamp(localX, 0, maxX), Math.Clamp(localY, 0, maxY));
		await InvokeAsync(StateHasChanged);
	}

	private void EndDrag(PointerEventArgs _)
	{
		_draggingBox = null;
		_canvasRect = null;
	}

	private void UpdateBoxPosition(string boxId, double x, double y)
	{
		if (IsTankTransfer)
		{
			switch (boxId)
			{
				case BoxId.Source:
					_tankTransferLayout.SourceX = x;
					_tankTransferLayout.TopRowY = y;
					break;
				case BoxId.Destination:
					_tankTransferLayout.DestinationX = x;
					_tankTransferLayout.TopRowY = y;
					break;
				case BoxId.Blower:
					_tankTransferLayout.BlowerX = x;
					_tankTransferLayout.BottomRowY = y;
					break;
				case BoxId.Airlock:
					_tankTransferLayout.AirlockX = x;
					_tankTransferLayout.BottomRowY = y;
					break;
				case BoxId.Blowline:
					_tankTransferLayout.BlowlineX = x;
					_tankTransferLayout.BottomRowY = y;
					break;
			}
			return;
		}

		switch (boxId)
		{
			case BoxId.GrainFilter:
				_grainDryerLayout.FilterBoxX = x;
				_grainDryerLayout.FilterBoxY = y;
				break;
			case BoxId.GrainExhaust:
				_grainDryerLayout.ExhaustBoxX = x;
				_grainDryerLayout.ExhaustBoxY = y;
				break;
			case BoxId.WetBin:
				_grainDryerLayout.WetBinX = x;
				_grainDryerLayout.WetBinY = y;
				break;
			case BoxId.DryerColumn:
				_grainDryerLayout.DryerColumnX = x;
				_grainDryerLayout.DryerColumnY = y;
				break;
			case BoxId.DryBin:
				_grainDryerLayout.DryBinX = x;
				_grainDryerLayout.DryBinY = y;
				break;
			case BoxId.FanModule:
				_grainDryerLayout.FanModuleX = x;
				_grainDryerLayout.FanModuleY = y;
				break;
			case BoxId.FeedScrew:
				_grainDryerLayout.FeedScrewX = x;
				_grainDryerLayout.FeedScrewY = y;
				break;
			case BoxId.BurnerModule:
				_grainDryerLayout.BurnerModuleX = x;
				_grainDryerLayout.BurnerModuleY = y;
				break;
			case BoxId.FeedModule:
				_grainDryerLayout.FeedModuleX = x;
				_grainDryerLayout.FeedModuleY = y;
				break;
			case BoxId.DischargeConveyor:
				_grainDryerLayout.DischargeConveyorX = x;
				_grainDryerLayout.DischargeConveyorY = y;
				break;
		}
	}

	private bool TryGetEditorBox(string boxId, out EditorBox box)
	{
		var match = EditorBoxes.FirstOrDefault(candidate => string.Equals(candidate.Id, boxId, StringComparison.Ordinal));
		box = match ?? EmptyEditorBox;
		return match is not null;
	}

	private List<EditorBox> BuildTankTransferEditorBoxes() =>
	[
		new(BoxId.Source, "Source Tank", "Top row", _tankTransferLayout.SourceX, _tankTransferLayout.TopRowY, _tankTransferLayout.BoxWidth, TankEditorBoxHeight),
		new(BoxId.Destination, "Destination Tank", "Top row", _tankTransferLayout.DestinationX, _tankTransferLayout.TopRowY, _tankTransferLayout.BoxWidth, TankEditorBoxHeight),
		new(BoxId.Blower, "Blower", "Bottom row", _tankTransferLayout.BlowerX, _tankTransferLayout.BottomRowY, _tankTransferLayout.BoxWidth, TankEditorBoxHeight),
		new(BoxId.Airlock, "Rotary Airlock", "Bottom row", _tankTransferLayout.AirlockX, _tankTransferLayout.BottomRowY, _tankTransferLayout.BoxWidth, TankEditorBoxHeight),
		new(BoxId.Blowline, "Blowline", "Bottom row", _tankTransferLayout.BlowlineX, _tankTransferLayout.BottomRowY, _tankTransferLayout.BoxWidth, TankEditorBoxHeight),
	];

	private List<EditorBox> BuildGrainDryerEditorBoxes() =>
	[
		new(BoxId.GrainFilter, "Filter Pressure", "Top instrument", _grainDryerLayout.FilterBoxX, _grainDryerLayout.FilterBoxY, 86, 92),
		new(BoxId.GrainExhaust, "Exhaust Header", "Top instrument", _grainDryerLayout.ExhaustBoxX, _grainDryerLayout.ExhaustBoxY, 86, 92),
		new(BoxId.WetBin, "Wet Bin", "Inventory", _grainDryerLayout.WetBinX, _grainDryerLayout.WetBinY, 122, 208),
		new(BoxId.DryerColumn, "Drying Column", "Core process", _grainDryerLayout.DryerColumnX, _grainDryerLayout.DryerColumnY, 278, 266),
		new(BoxId.DryBin, "Dry Bin", "Inventory", _grainDryerLayout.DryBinX, _grainDryerLayout.DryBinY, 122, 208),
		new(BoxId.FanModule, "Fan", "Utility", _grainDryerLayout.FanModuleX, _grainDryerLayout.FanModuleY, 132, 66),
		new(BoxId.FeedScrew, "Feed Screw", "Conveyor", _grainDryerLayout.FeedScrewX, _grainDryerLayout.FeedScrewY, 44, 166),
		new(BoxId.BurnerModule, "Burner", "Heat source", _grainDryerLayout.BurnerModuleX, _grainDryerLayout.BurnerModuleY, 132, 66),
		new(BoxId.FeedModule, "Feed Drive", "Utility", _grainDryerLayout.FeedModuleX, _grainDryerLayout.FeedModuleY, 132, 66),
		new(BoxId.DischargeConveyor, "Discharge Conveyor", "Conveyor", _grainDryerLayout.DischargeConveyorX, _grainDryerLayout.DischargeConveyorY, 180, 40),
	];

	private sealed class ClientRect
	{
		public double Left { get; set; }
		public double Top { get; set; }
		public double Width { get; set; }
		public double Height { get; set; }
	}

	private static class BoxId
	{
		public const string Source = "source";
		public const string Destination = "destination";
		public const string Blower = "blower";
		public const string Airlock = "airlock";
		public const string Blowline = "blowline";
		public const string GrainFilter = "grain-filter";
		public const string GrainExhaust = "grain-exhaust";
		public const string WetBin = "wet-bin";
		public const string DryerColumn = "dryer-column";
		public const string DryBin = "dry-bin";
		public const string FanModule = "fan-module";
		public const string FeedScrew = "feed-screw";
		public const string BurnerModule = "burner-module";
		public const string FeedModule = "feed-module";
		public const string DischargeConveyor = "discharge-conveyor";
	}

	private static readonly EditorBox EmptyEditorBox = new(string.Empty, string.Empty, string.Empty, 0, 0, 0, 0);

	private sealed record EditorBox(string Id, string Title, string Subtitle, double X, double Y, double Width, double Height);
}
