	private async Task LoadAlarmHistorySeedAsync(CancellationToken cancellationToken)
	{
		try
		{
			var batch = await Api.GetLogsAsync(SimId, take: 40, cancellationToken: cancellationToken);
			foreach (var entry in batch.Entries.Where(IsAlarmLikeLogEntry).OrderByDescending(e => e.Timestamp).Take(8).Reverse())
			{
				AppendAlarmHistory(entry.Timestamp, entry.Level, entry.Message, SeverityClassForLog(entry));
			}
		}
		catch
		{
		}
	}

	private void TrackAlarmTransitions(TelemetrySnapshot snapshot)
	{
		var alarmSignals = snapshot.Signals.Where(kvp => IsAlarmSignal(kvp.Key)).ToArray();

		if (!_hasAlarmStateSeed)
		{
			_alarmSignalStates.Clear();
			foreach (var kvp in alarmSignals)
			{
				_alarmSignalStates[kvp.Key] = kvp.Value >= 0.5;
			}

			_hasAlarmStateSeed = true;
			return;
		}

		foreach (var kvp in alarmSignals)
		{
			var isActive = kvp.Value >= 0.5;
			if (_alarmSignalStates.TryGetValue(kvp.Key, out var previous) && previous != isActive)
			{
				AppendAlarmHistory(
					DateTimeOffset.UtcNow,
					HumanizeKey(kvp.Key),
					isActive ? "Alarm asserted from live signal state." : "Alarm cleared from live signal state.",
					isActive ? "severity-alarm" : "severity-clear");
			}

			_alarmSignalStates[kvp.Key] = isActive;
		}
	}

	private void AppendAlarmHistory(DateTimeOffset timestamp, string title, string detail, string severityClass)
	{
		_alarmHistory.Insert(0, new AlarmHistoryEntry(timestamp, title, detail, severityClass));
		if (_alarmHistory.Count > 20)
		{
			_alarmHistory.RemoveRange(20, _alarmHistory.Count - 20);
		}
	}

	private static bool IsAlarmSignal(string key) =>
		key.Contains("Alarm", StringComparison.OrdinalIgnoreCase)
		|| key.Contains("Fault", StringComparison.OrdinalIgnoreCase)
		|| key.Contains("Trip", StringComparison.OrdinalIgnoreCase);

	private static bool IsAlarmLikeLogEntry(LogEntryDto entry) =>
		entry.Level.Contains("warn", StringComparison.OrdinalIgnoreCase)
		|| entry.Level.Contains("error", StringComparison.OrdinalIgnoreCase)
		|| entry.Message.Contains("alarm", StringComparison.OrdinalIgnoreCase)
		|| entry.Message.Contains("fault", StringComparison.OrdinalIgnoreCase)
		|| entry.Message.Contains("trip", StringComparison.OrdinalIgnoreCase);

	private static string SeverityClassForLog(LogEntryDto entry)
	{
		if (entry.Level.Contains("error", StringComparison.OrdinalIgnoreCase))
		{
			return "severity-alarm";
		}

		if (entry.Level.Contains("warn", StringComparison.OrdinalIgnoreCase))
		{
			return "severity-warn";
		}

		return "severity-info";
	}

	private static string HumanizeKey(string key)
	{
		if (string.IsNullOrWhiteSpace(key))
		{
			return string.Empty;
		}

		var builder = new System.Text.StringBuilder(key.Length + 8);
		for (var i = 0; i < key.Length; i++)
		{
			var c = key[i];
			if (i > 0 && char.IsUpper(c) && (char.IsLower(key[i - 1]) || char.IsDigit(key[i - 1])))
			{
				builder.Append(' ');
			}

			builder.Append(c);
		}

		return builder.ToString();
	}

