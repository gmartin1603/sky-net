@page "/sim/{SimId}"

@using SkyNet.Simulator.Contracts
@using SkyNet.Simulator.Dashboard.Components
@using SkyNet.Simulator.Dashboard.Services
@implements IAsyncDisposable

@inject SimApiClient Api
@inject SimHubClient Hub
@inject DaemonClientOptions Options
@inject SimViewCache ViewCache
@inject SimulationViewLayoutStore LayoutStore

<PageTitle>Simulation</PageTitle>

<section class="opsb-shell">
	<div class="opsb-hero">
		<div>
			<p class="opsb-kicker">@(IsTrainerView ? "Trainer Console" : "Industrial Console")</p>
			<h1>@SimulationTitle</h1>
			<p class="opsb-copy">@SimulationDescription</p>
		</div>
		<div class="opsb-hero-meta">
			<div>
				<span class="opsb-meta-label">View</span>
				<strong class="@(IsTrainerView ? "is-alert" : "is-live")">@CurrentViewLabel</strong>
			</div>
			<div>
				<span class="opsb-meta-label">Simulation</span>
				<strong><code>@SimId</code></strong>
			</div>
			<div>
				<span class="opsb-meta-label">Daemon</span>
				<strong><code>@Options.BaseUri</code></strong>
			</div>
			<div>
				<span class="opsb-meta-label">Connection</span>
				<strong class="@(Hub.IsConnected ? "is-live" : "is-idle")">@ConnectionLabel</strong>
			</div>
			<div>
				<span class="opsb-meta-label">Alarm State</span>
				<strong class="@(ActiveAlarmCount > 0 ? "is-alert" : "is-live")">@(ActiveAlarmCount > 0 ? $"{ActiveAlarmCount} active" : "Normal")</strong>
			</div>
		</div>
	</div>

	<div class="opsb-command-strip">
		<div class="opsb-command-primary">
			<div class="opsb-view-switch" role="tablist" aria-label="Dashboard view">
				<a class="opsb-view-link @(!IsTrainerView ? "is-active" : string.Empty)" href="@BuildViewHref(false)">Trainee View</a>
				<a class="opsb-view-link @(IsTrainerView ? "is-active" : string.Empty)" href="@BuildViewHref(true)">Trainer View</a>
			</div>
			<button type="button" class="opsb-command-button opsb-command-button-primary" @onclick="OpenRunOverlay">Console Runboard</button>
			@if (SupportsLayoutCreator)
			{
				<a class="opsb-command-link" href="@($"sim/{Uri.EscapeDataString(SimId)}/creator")">Open layout editor</a>
			}
			@if (IsTrainerView)
			{
				<button type="button" class="opsb-command-button" @onclick="OpenEngineeringOverlay">Maintenance Access</button>
			}
		</div>
		<div class="opsb-run-meta">
			<div>
				<span class="opsb-meta-label">State</span>
				<strong class="@(_status?.IsPaused ?? true ? "is-idle" : "is-live")">@RunStateLabel</strong>
			</div>
			<div>
				<span class="opsb-meta-label">Tick</span>
				<strong>@(_uiSnapshot?.Tick ?? 0)</strong>
			</div>
			<div>
				<span class="opsb-meta-label">Sim Time</span>
				<strong>@FormatSimTime()</strong>
			</div>
		</div>
	</div>

	@if (!string.IsNullOrWhiteSpace(_error))
	{
		<div class="opsb-alert">
			<strong>Error:</strong> @_error
		</div>
	}

	@if (IsTrainerView)
	{
		<section class="opsb-trainer-workspace">
			<div class="opsb-trainer-rail">
				<div class="opsb-trainer-banner">
					<strong>Trainer controls are live.</strong> Scenario disturbances, saved scenarios, and trainer events are grouped here so the trainee operating panel can stay focused on response and recovery.
				</div>

				@if (_uiSnapshot is not null)
				{
					@switch (SimId.ToLowerInvariant())
					{
						case "tank-transfer":
							<TankTransferTrainerPanel SimId="@SimId" Snapshot="@_uiSnapshot" />
							break;
						case "grain-dryer":
							<GrainDryerTrainerPanel SimId="@SimId" Snapshot="@_uiSnapshot" />
							break;
						default:
							if (IsHydraulicSimulation(SimId))
							{
								<HydraulicTrainerPanel SimId="@SimId" Snapshot="@_uiSnapshot" />
							}
							break;
					}
				}
			</div>

			<TrainerConsole SimId="@SimId" Snapshot="@_uiSnapshot" PresetParameterNames="@TrainerPresetParameterNames" />
		</section>
	}

	@if (_uiSnapshot is null)
	{
		<div class="opsb-empty">Waiting for telemetry...</div>
	}
	else
	{
		@if (string.Equals(SimId, "tank-transfer", StringComparison.OrdinalIgnoreCase)
			|| string.Equals(SimId, "grain-dryer", StringComparison.OrdinalIgnoreCase))
		{
			var isTankTransfer = string.Equals(SimId, "tank-transfer", StringComparison.OrdinalIgnoreCase);
			var focusedSceneClass = isTankTransfer ? "is-tank-transfer" : "is-grain-dryer";

			<div class="opsb-layout opsb-layout-focus">
				<div class="opsb-main-column opsb-main-column-focus">
					<section class="opsb-panel opsb-viewport-panel opsb-viewport-panel-focus opsb-panel-dense">
						<div class="opsb-panel-head opsb-panel-head-focus">
							<div>
								<p class="opsb-section-kicker">Primary HMI</p>
								<h2>@SchematicTitle</h2>
							</div>
							<div class="opsb-viewport-badges">
								<span class="opsb-badge">Embedded HMI</span>
								<span class="opsb-badge">@CurrentViewLabel</span>
								<span class="opsb-badge @(ActiveAlarmCount > 0 ? "is-alert" : "is-live")">@(ActiveAlarmCount > 0 ? "Respond now" : "Steady")</span>
							</div>
						</div>
						<div class="opsb-viewport-frame opsb-viewport-frame-focus">
							<div class="opsb-viewport-scene @focusedSceneClass">
								@if (isTankTransfer)
								{
									<TankTransferSchematic SimId="@SimId" Snapshot="@_uiSnapshot" Layout="@_tankTransferLayout" />
								}
								else
								{
									<GrainDryerSchematic SimId="@SimId" Snapshot="@_uiSnapshot" Layout="@_grainDryerLayout" />
								}
							</div>
						</div>
					</section>

					<section class="opsb-panel opsb-panel-dense opsb-alarm-table-panel">
						<div class="opsb-panel-head">
							<div>
								<p class="opsb-section-kicker">Alarm Management</p>
								<h2>Annunciator Table</h2>
							</div>
						</div>
						<div class="opsb-alarm-table-grid">
							<section class="opsb-alarm-table-card">
								<div class="opsb-history-head">
									<span class="opsb-meta-label">Active Alarms</span>
								</div>
								@if (ActiveAlarms.Count == 0)
								{
									<div class="opsb-empty-inline">No active alarms. Console remains in steady operation.</div>
								}
								else
								{
									<div class="table-responsive">
										<table class="table table-sm align-middle opsb-alarm-table">
											<thead>
												<tr>
													<th>Alarm</th>
													<th>Value</th>
													<th>State</th>
												</tr>
											</thead>
											<tbody>
												@foreach (var alarm in ActiveAlarms)
												{
													<tr>
														<td>@HumanizeKey(alarm.Key)</td>
														<td>@alarm.Value.ToString("0.###")</td>
														<td><span class="opsb-alarm-pill">Active</span></td>
													</tr>
												}
											</tbody>
										</table>
									</div>
								}
							</section>

							<section class="opsb-alarm-table-card">
								<div class="opsb-history-head">
									<span class="opsb-meta-label">Recent Alarm History</span>
								</div>
								@if (_alarmHistory.Count == 0)
								{
									<div class="opsb-empty-inline">No annunciated transitions captured in this shift window.</div>
								}
								else
								{
									<div class="table-responsive">
										<table class="table table-sm align-middle opsb-alarm-table opsb-alarm-history-table">
											<thead>
												<tr>
													<th>Time</th>
													<th>Alarm</th>
													<th>Detail</th>
												</tr>
											</thead>
											<tbody>
												@foreach (var entry in _alarmHistory)
												{
													<tr class="@entry.SeverityClass">
														<td>@FormatHistoryTime(entry.Timestamp)</td>
														<td>@entry.Title</td>
														<td>@entry.Detail</td>
													</tr>
												}
											</tbody>
										</table>
									</div>
								}
							</section>
						</div>
					</section>

					@if (isTankTransfer)
					{
						<TankTransferOperatorPanel SimId="@SimId" Snapshot="@_uiSnapshot" />
					}
					else
					{
						<GrainDryerOperatorPanel SimId="@SimId" Snapshot="@_uiSnapshot" />
					}

					<section class="opsb-panel opsb-panel-dense">
						<div class="opsb-panel-head">
							<div>
								<p class="opsb-section-kicker">History</p>
								<h2>Recorder Banks</h2>
							</div>
						</div>
						<div class="opsb-chart-grid">
							<LineChart PanelClass="opsb-chart-panel opsb-chart-panel-one" Title="@_chart1Title" SubTitle="@_chart1Unit" Stroke="var(--chart-series-1)" Points="@_pressureSeries" YFormat="@_chart1Format" />
							<LineChart PanelClass="opsb-chart-panel opsb-chart-panel-two" Title="@_chart2Title" SubTitle="@_chart2Unit" Stroke="var(--chart-series-2)" Points="@_positionSeries" YFormat="@_chart2Format" />
							<LineChart PanelClass="opsb-chart-panel opsb-chart-panel-three" Title="@_chart3Title" SubTitle="@_chart3Unit" Stroke="var(--chart-series-3)" Points="@_flowSeries" YFormat="@_chart3Format" />
						</div>
					</section>
				</div>
			</div>
		}
		else
		{
			<div class="opsb-layout">
				<div class="opsb-main-column">
					@if (string.Equals(SimId, "grain-dryer", StringComparison.OrdinalIgnoreCase))
					{
						<GrainDryerOperatorPanel SimId="@SimId" Snapshot="@_uiSnapshot" />
					}
					else if (IsHydraulicSimulation(SimId))
					{
						<HydraulicOperatorPanel SimId="@SimId" Snapshot="@_uiSnapshot" />
					}

					<section class="opsb-panel opsb-viewport-panel opsb-panel-dense">
						<div class="opsb-panel-head">
							<div>
								<p class="opsb-section-kicker">Live View</p>
								<h2>@SchematicTitle</h2>
							</div>
							<div class="opsb-viewport-badges">
								<span class="opsb-badge">Embedded HMI</span>
								<span class="opsb-badge">@CurrentViewLabel</span>
								<span class="opsb-badge @(ActiveAlarmCount > 0 ? "is-alert" : "is-live")">@(ActiveAlarmCount > 0 ? "Respond now" : "Steady")</span>
							</div>
						</div>
						<div class="opsb-viewport-frame">
							<div class="opsb-viewport-overlay opsb-viewport-overlay-top">
								<div>
									<span class="opsb-meta-label">Console</span>
									<strong>@SimulationTitle</strong>
								</div>
								<div>
									<span class="opsb-meta-label">Operating state</span>
									<strong class="@(ActiveAlarmCount > 0 ? "is-alert" : "is-live")">@(ActiveAlarmCount > 0 ? "Respond" : "Watching")</strong>
								</div>
								<div>
									<span class="opsb-meta-label">Tick Rate</span>
									<strong>@(_status?.StepSeconds.ToString("0.000") ?? "0.000")s</strong>
								</div>
							</div>
							<div class="opsb-viewport-scene">
								@if (string.Equals(SimId, "grain-dryer", StringComparison.OrdinalIgnoreCase))
								{
									<GrainDryerSchematic SimId="@SimId" Snapshot="@_uiSnapshot" Layout="@_grainDryerLayout" />
								}
								else if (IsHydraulicSimulation(SimId))
								{
									<HydraulicSchematic SimId="@SimId" Snapshot="@_uiSnapshot" />
								}
							</div>
							<div class="opsb-viewport-overlay opsb-viewport-overlay-bottom">
								@foreach (var item in ViewportOverlayMetrics)
								{
									<div>
										<span class="opsb-meta-label">@item.Label</span>
										<strong>@item.Value</strong>
									</div>
								}
							</div>
						</div>
					</section>

					<section class="opsb-panel opsb-panel-dense">
						<div class="opsb-panel-head">
							<div>
								<p class="opsb-section-kicker">Signal Watch</p>
								<h2>Instrument Bus</h2>
							</div>
						</div>
						<div class="opsb-signal-grid">
							@foreach (var key in _keySignals)
							{
								var value = _uiSnapshot.Signals.TryGetValue(key, out var v) ? v : double.NaN;
								<div class="opsb-signal-tile @(IsAlarmSignal(key) && value >= 0.5 ? "is-alarm" : string.Empty)">
									<div class="opsb-signal-name">@HumanizeKey(key)</div>
									<div class="opsb-signal-value">@value.ToString("0.###")</div>
								</div>
							}
						</div>
					</section>

					<section class="opsb-panel opsb-panel-dense">
						<div class="opsb-panel-head">
							<div>
								<p class="opsb-section-kicker">History</p>
								<h2>Recorder Banks</h2>
							</div>
						</div>
						<div class="opsb-chart-grid">
							<LineChart PanelClass="opsb-chart-panel opsb-chart-panel-one" Title="@_chart1Title" SubTitle="@_chart1Unit" Stroke="var(--chart-series-1)" Points="@_pressureSeries" YFormat="@_chart1Format" />
							<LineChart PanelClass="opsb-chart-panel opsb-chart-panel-two" Title="@_chart2Title" SubTitle="@_chart2Unit" Stroke="var(--chart-series-2)" Points="@_positionSeries" YFormat="@_chart2Format" />
							<LineChart PanelClass="opsb-chart-panel opsb-chart-panel-three" Title="@_chart3Title" SubTitle="@_chart3Unit" Stroke="var(--chart-series-3)" Points="@_flowSeries" YFormat="@_chart3Format" />
						</div>
					</section>
				</div>

				<aside class="opsb-side-column">
					<section class="opsb-panel opsb-side-panel opsb-panel-dense">
						<div class="opsb-panel-head">
							<div>
								<p class="opsb-section-kicker">System Status</p>
								<h2>Shift Summary</h2>
							</div>
						</div>
						<div class="opsb-side-metrics">
							<div>
								<span class="opsb-meta-label">Run State</span>
								<strong>@RunStateLabel</strong>
							</div>
							<div>
								<span class="opsb-meta-label">Connection</span>
								<strong>@ConnectionLabel</strong>
							</div>
							<div>
								<span class="opsb-meta-label">Tracked Signals</span>
								<strong>@_sortedSignals.Length</strong>
							</div>
							<div>
								<span class="opsb-meta-label">Alarm History</span>
								<strong>@_alarmHistory.Count items</strong>
							</div>
						</div>
					</section>

					<section class="opsb-panel opsb-side-panel opsb-panel-dense">
						<div class="opsb-panel-head">
							<div>
								<p class="opsb-section-kicker">Active Alarms</p>
								<h2>Annunciator Board</h2>
							</div>
						</div>
						@if (ActiveAlarms.Count == 0)
						{
							<div class="opsb-empty-inline">No active alarms. No annunciated faults. Console remains in steady operation.</div>
						}
						else
						{
							<div class="opsb-alarm-list">
								@foreach (var alarm in ActiveAlarms)
								{
									<div class="opsb-alarm-item is-active">
										<div>
											<strong>@HumanizeKey(alarm.Key)</strong>
											<p>Signal value @alarm.Value.ToString("0.###")</p>
										</div>
										<span class="opsb-alarm-pill">Active</span>
									</div>
								}
							</div>
						}

						<div class="opsb-history-head">
							<span class="opsb-meta-label">Recent Alarm History</span>
						</div>
						@if (_alarmHistory.Count == 0)
						{
							<div class="opsb-empty-inline">No annunciated transitions captured in this shift window.</div>
						}
						else
						{
							<div class="opsb-history-list">
								@foreach (var entry in _alarmHistory)
								{
									<div class="opsb-history-item @entry.SeverityClass">
										<div>
											<strong>@entry.Title</strong>
											<p>@entry.Detail</p>
										</div>
										<span>@FormatHistoryTime(entry.Timestamp)</span>
									</div>
								}
							</div>
						}
					</section>

					<section class="opsb-panel opsb-side-panel opsb-panel-dense">
						<div class="opsb-panel-head">
							<div>
								<p class="opsb-section-kicker">Diagnostics</p>
								<h2>Quick Gauges</h2>
							</div>
						</div>
						<div class="opsb-fast-list">
							@foreach (var kvp in FastReadbackSignals)
							{
								<div>
									<span class="opsb-meta-label">@HumanizeKey(kvp.Key)</span>
									<strong>@kvp.Value.ToString("0.###")</strong>
								</div>
							}
						</div>
					</section>
				</aside>
			</div>
		}

		<section class="opsb-panel opsb-diagnostics-panel opsb-panel-dense">
			<div class="opsb-panel-head">
				<div>
					<p class="opsb-section-kicker">Diagnostics</p>
					<h2>All Signals</h2>
				</div>
			</div>
			@if (_sortedSignals.Length == 0)
			{
				<p>No signals yet.</p>
			}
			else
			{
				<div class="table-responsive">
					<table class="table table-sm align-middle">
						<thead>
							<tr>
								<th>Name</th>
								<th>Value</th>
							</tr>
						</thead>
						<tbody>
							@foreach (var kvp in _sortedSignals)
							{
								<tr>
									<td><code>@kvp.Key</code></td>
									<td>@kvp.Value.ToString("0.###")</td>
								</tr>
							}
						</tbody>
					</table>
				</div>
			}
		</section>
	}
</section>

<OpsModal Visible="@_showRunOverlay" Title="Console runboard" Subtitle="Primary run commands stay in a protected console drawer with immediate status readback." OnClose="CloseRunOverlay">
	<div class="opsb-modal-grid">
		<section class="opsb-modal-panel">
			<div class="opsb-control-group">
				<button class="btn btn-primary" @onclick="Pause" disabled="@(_status?.IsPaused ?? false)">Pause</button>
				<button class="btn btn-primary" @onclick="Resume" disabled="@(!(_status?.IsPaused ?? true))">@(_status?.Tick == 0 ? "Start" : "Resume")</button>
				<button class="btn btn-outline-secondary" @onclick="StepOnce" disabled="@(!(_status?.IsPaused ?? false))">Step</button>
			</div>
		</section>
		<section class="opsb-modal-panel opsb-side-metrics">
			<div>
				<span class="opsb-meta-label">State</span>
				<strong>@RunStateLabel</strong>
			</div>
			<div>
				<span class="opsb-meta-label">Tick</span>
				<strong>@(_uiSnapshot?.Tick ?? 0)</strong>
			</div>
			<div>
				<span class="opsb-meta-label">Time</span>
				<strong>@FormatSimTime()</strong>
			</div>
			<div>
				<span class="opsb-meta-label">Alarms</span>
				<strong>@ActiveAlarmCount active</strong>
			</div>
		</section>
	</div>
</OpsModal>

<OpsModal Visible="@_showEngineeringOverlay" Title="Maintenance access" Subtitle="Parameter edits move into a maintenance drawer so the main console stays focused on operation and alarms." OnClose="CloseEngineeringOverlay">
	@if (_parameterDefinitions is null)
	{
		<p>Loading parameter definitions...</p>
	}
	else
	{
		<div class="table-responsive">
			<table class="table table-sm align-middle">
				<thead>
					<tr>
						<th>Name</th>
						<th>Value</th>
						<th>Min</th>
						<th>Max</th>
						<th>Set</th>
						<th>Description</th>
					</tr>
				</thead>
				<tbody>
					@foreach (var def in _parameterDefinitions)
					{
						var snap = _tableSnapshot ?? _uiSnapshot;
						double current;
						if (snap is not null && snap.Parameters.TryGetValue(def.Name, out var vSnap))
						{
							current = vSnap;
						}
						else if (_lastParameterValues.TryGetValue(def.Name, out var vPoll))
						{
							current = vPoll;
						}
						else
						{
							current = double.NaN;
						}
						_parameterEdits.TryGetValue(def.Name, out var edit);

						<tr>
							<td><code>@def.Name</code></td>
							<td>@current.ToString("0.###")</td>
							<td>@(def.MinValue?.ToString("0.###") ?? "-")</td>
							<td>@(def.MaxValue?.ToString("0.###") ?? "-")</td>
							<td class="opsb-param-setter">
								<input class="form-control form-control-sm d-inline-block" type="number" step="any" value="@edit" @onchange="e => OnEditChanged(def.Name, e)" />
								<button class="btn btn-sm btn-primary" @onclick="() => ApplyParameter(def.Name)">Set</button>
							</td>
							<td>@def.Description</td>
						</tr>
					}
				</tbody>
			</table>
		</div>
	}
</OpsModal>

@code {
	[Parameter] public string SimId { get; set; } = string.Empty;
	[Parameter, SupplyParameterFromQuery(Name = "view")] public string? View { get; set; }

	private readonly object _seriesLock = new();
	private const int MaxPoints = 600;

	private string[] _keySignals =
	[
		"DownstreamPressurePsi",
		"DownstreamPressureSensorPsi",
		"ValveFlowGpm",
		"ActuatorPosition",
		"ActuatorVelocity",
	];

	private string _chart1Title = "Downstream Pressure";
	private string? _chart1Unit = "psi";
	private string _chart1SignalKey = "DownstreamPressurePsi";
	private string _chart1Format = "0.0";

	private string _chart2Title = "Actuator Position";
	private string? _chart2Unit = "pos";
	private string _chart2SignalKey = "ActuatorPosition";
	private string _chart2Format = "0.000";

	private string _chart3Title = "Valve Flow";
	private string? _chart3Unit = "gpm";
	private string _chart3SignalKey = "ValveFlowGpm";
	private string _chart3Format = "0.0";

	private bool _showRunOverlay;
	private bool _showEngineeringOverlay;
	private bool _hasAlarmStateSeed;
	private readonly List<AlarmHistoryEntry> _alarmHistory = new();
	private readonly Dictionary<string, bool> _alarmSignalStates = new(StringComparer.OrdinalIgnoreCase);

	private LineChart.Point[] _pressureSeries = Array.Empty<LineChart.Point>();
	private LineChart.Point[] _positionSeries = Array.Empty<LineChart.Point>();
