@namespace SkyNet.Simulator.Dashboard.Components

@{
	var voluteX = 80.0;
	var voluteY = CenterY;
}

<g class="schematic-glyph schematic-pump">
	<line x1="10" y1="@CenterY" x2="52" y2="@CenterY" stroke="@VisualStyle.DetailStroke" stroke-width="4" stroke-linecap="round" />
	<line x1="108" y1="@CenterY" x2="156" y2="@CenterY" stroke="@VisualStyle.DetailStroke" stroke-width="4" stroke-linecap="round" />
	<path d="M52 @(CenterY - 28) A28 28 0 1 1 52 @(CenterY + 28) L84 @(CenterY + 14) A12 12 0 1 0 84 @(CenterY - 14) Z" fill="@VisualStyle.ShellFill" stroke="@VisualStyle.ShellStroke" stroke-width="2.4" />
	<circle cx="@voluteX" cy="@voluteY" r="8" fill="@VisualStyle.CoreFill" stroke="@VisualStyle.ShellStroke" stroke-width="1.8" />
	<rect x="150" y="@(CenterY - 20)" width="38" height="40" rx="10" ry="10" fill="@VisualStyle.ShellFill" stroke="@VisualStyle.ShellStroke" stroke-width="2.4" />
	<rect x="46" y="@(CenterY + 34)" width="144" height="10" rx="5" ry="5" fill="@VisualStyle.BaseFill" />
</g>

@code {
	[CascadingParameter] public SchematicVisualStyle VisualStyle { get; set; } = SchematicVisualStyle.Default;
	[Parameter] public double CenterY { get; set; } = 100;
}