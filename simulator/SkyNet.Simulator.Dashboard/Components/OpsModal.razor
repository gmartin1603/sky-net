@if (Visible)
{
	<div class="ops-modal-backdrop" @onclick="HandleCloseAsync">
		<div class="ops-modal-card" role="dialog" aria-modal="true" aria-label="@Title" @onclick:stopPropagation="true">
			<div class="ops-modal-head">
				<div>
					<p class="ops-modal-kicker">Operator Overlay</p>
					<h2>@Title</h2>
					@if (!string.IsNullOrWhiteSpace(Subtitle))
					{
						<p class="ops-modal-copy">@Subtitle</p>
					}
				</div>
				<button type="button" class="ops-modal-close" @onclick="HandleCloseAsync">Close</button>
			</div>

			<div class="ops-modal-body">
				@ChildContent
			</div>
		</div>
	</div>
}

@code {
	[Parameter] public bool Visible { get; set; }
	[Parameter] public string Title { get; set; } = string.Empty;
	[Parameter] public string? Subtitle { get; set; }
	[Parameter] public RenderFragment? ChildContent { get; set; }
	[Parameter] public EventCallback OnClose { get; set; }

	private Task HandleCloseAsync() => OnClose.InvokeAsync();
}
