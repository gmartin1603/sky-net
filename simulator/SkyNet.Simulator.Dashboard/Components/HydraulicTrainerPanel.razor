@using System.Globalization
@using SkyNet.Simulator.Contracts
@using SkyNet.Simulator.Dashboard.Services

@inject SimApiClient Api

<section class="hyd-ops-card hyd-ops-card-wide hyd-ops-card-trainer hyd-ops-card-full">
	<div class="hyd-ops-card-head">
		<h3>Trainer Disturbances</h3>
		<span class="hyd-ops-chip hyd-ops-chip-alert">Scenario</span>
	</div>
	<p class="hyd-ops-copy">Inject sensor and supply faults so the trainee has to decide whether the issue is real pressure loss, bad instrumentation, or changing load.</p>
	<div class="hyd-ops-dual-grid has-tertiary">
		<div>
			<label class="hyd-ops-field-label" for="hyd-sensor-bias">Sensor Bias</label>
			<div class="hyd-ops-input-row">
				<input id="hyd-sensor-bias" class="hyd-ops-input" type="number" min="-500" max="500" step="10" value="@_sensorBiasDraft" @onchange="OnSensorBiasChanged" />
				<button type="button" class="hyd-ops-apply" @onclick="ApplySensorBiasAsync">Apply</button>
			</div>
		</div>
		<div>
			<label class="hyd-ops-field-label" for="hyd-supply-sag">Supply Sag</label>
			<div class="hyd-ops-input-row">
				<input id="hyd-supply-sag" class="hyd-ops-input" type="number" min="0" max="80" step="5" value="@_supplySagDraft" @onchange="OnSupplySagChanged" />
				<button type="button" class="hyd-ops-apply" @onclick="ApplySupplySagAsync">Apply</button>
			</div>
		</div>
		<div>
			<label class="hyd-ops-field-label">Sensor Freeze</label>
			<div class="hyd-ops-step-row">
				<button type="button" class="hyd-ops-step" @onclick="() => SetNumericParameterAsync(ParamSensorFaultActive, SensorFaultActive ? 0.0 : 1.0, 0.0, 1.0)">@((SensorFaultActive ? "Clear freeze" : "Freeze sensor"))</button>
			</div>
		</div>
	</div>
	<div class="hyd-ops-readback-grid">
		<div>
			<span class="hyd-ops-readback-label">Sensor bias</span>
			<strong>@SensorBiasPsi.ToString("0", CultureInfo.InvariantCulture) psi</strong>
		</div>
		<div>
			<span class="hyd-ops-readback-label">Supply sag</span>
			<strong>@(SupplyPressureSagPercent * 100.0).ToString("0", CultureInfo.InvariantCulture)%</strong>
		</div>
		<div>
			<span class="hyd-ops-readback-label">Sensor freeze</span>
			<strong>@(SensorFaultActive ? "Active" : "Clear")</strong>
		</div>
	</div>
</section>

@code {
	[Parameter] public string SimId { get; set; } = string.Empty;
	[Parameter] public TelemetrySnapshot? Snapshot { get; set; }

	private const string ParamSensorBiasPsi = "SensorBiasPsi";
	private const string ParamSensorFaultActive = "SensorFaultActive";
	private const string ParamSupplyPressureSagPercent = "SupplyPressureSagPercent";

	private string _sensorBiasDraft = string.Empty;
	private string _supplySagDraft = string.Empty;
	private double? _lastSensorBias;
	private double? _lastSupplySag;

	protected override void OnParametersSet()
	{
		SyncDraft(ref _lastSensorBias, SensorBiasPsi, value => _sensorBiasDraft = value.ToString("0.0", CultureInfo.InvariantCulture));
		SyncDraft(ref _lastSupplySag, SupplyPressureSagPercent * 100.0, value => _supplySagDraft = value.ToString("0.0", CultureInfo.InvariantCulture));
	}

	private double SensorBiasPsi => GetParameter(ParamSensorBiasPsi);
	private double SupplyPressureSagPercent => GetParameter(ParamSupplyPressureSagPercent);
	private bool SensorFaultActive => GetParameter(ParamSensorFaultActive) >= 0.5;

	private double GetParameter(string name) => Snapshot?.Parameters.TryGetValue(name, out var value) == true ? value : 0.0;

	private void OnSensorBiasChanged(ChangeEventArgs e) => _sensorBiasDraft = e.Value?.ToString() ?? string.Empty;
	private void OnSupplySagChanged(ChangeEventArgs e) => _supplySagDraft = e.Value?.ToString() ?? string.Empty;

	private Task ApplySensorBiasAsync() => ApplyDraftAsync(ParamSensorBiasPsi, _sensorBiasDraft, SensorBiasPsi, -500.0, 500.0);
	private Task ApplySupplySagAsync() => ApplyDraftAsync(ParamSupplyPressureSagPercent, _supplySagDraft, SupplyPressureSagPercent * 100.0, 0.0, 80.0, divideByHundred: true);

	private async Task ApplyDraftAsync(string parameterName, string draft, double fallbackValue, double min, double max, bool divideByHundred = false)
	{
		var parsed = TryParseValue(draft, out var value) ? value : fallbackValue;
		if (divideByHundred)
		{
			parsed /= 100.0;
			min /= 100.0;
			max /= 100.0;
		}
		await SetNumericParameterAsync(parameterName, parsed, min, max);
	}

	private async Task SetNumericParameterAsync(string parameterName, double value, double min, double max)
	{
		if (string.IsNullOrWhiteSpace(SimId))
		{
			return;
		}

		var clamped = Math.Clamp(value, min, max);
		await Api.SetParameterAsync(SimId, parameterName, clamped);
		await Api.AddTrainerEventAsync(SimId, $"Hydraulic disturbance updated: {parameterName}={clamped:0.###}");
		if (string.Equals(parameterName, ParamSensorBiasPsi, StringComparison.OrdinalIgnoreCase))
		{
			_lastSensorBias = clamped;
			_sensorBiasDraft = clamped.ToString("0.0", CultureInfo.InvariantCulture);
		}
		else if (string.Equals(parameterName, ParamSupplyPressureSagPercent, StringComparison.OrdinalIgnoreCase))
		{
			_lastSupplySag = clamped * 100.0;
			_supplySagDraft = (clamped * 100.0).ToString("0.0", CultureInfo.InvariantCulture);
		}
	}

	private static bool TryParseValue(string? text, out double value)
	{
		return double.TryParse(text, NumberStyles.Float | NumberStyles.AllowThousands, CultureInfo.InvariantCulture, out value)
			|| double.TryParse(text, NumberStyles.Float | NumberStyles.AllowThousands, CultureInfo.CurrentCulture, out value);
	}

	private static void SyncDraft(ref double? lastSynced, double current, Action<double> apply)
	{
		if (!lastSynced.HasValue || Math.Abs(lastSynced.Value - current) > 1e-9)
		{
			apply(current);
			lastSynced = current;
		}
	}
}
