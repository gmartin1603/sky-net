<OpsModal Visible="@_showTrendModal" Title="@(_activeTrendMeta?.Tag ?? "Signal Trend")" Subtitle="@(_activeTrendMeta?.Label)" OnClose="CloseTrendModalAsync">
	@if (_activeTrendMeta is not null)
	{
		<div style="display:flex;gap:1.5rem;align-items:baseline;margin-bottom:0.5rem;">
			<div><span style="opacity:0.7;font-size:0.85rem;">Current value</span><br/><strong>@FormatTrendValue(_activeTrendMeta)</strong></div>
			<div><span style="opacity:0.7;font-size:0.85rem;">Signal</span><br/><strong>@_activeTrendMeta.Label</strong></div>
		</div>
		<LineChart Title="@_activeTrendMeta.Tag" SubTitle="@_activeTrendMeta.Unit" Stroke="var(--chart-series-2)" Points="@GetTrendPoints(_activeTrendMeta.Key)" YFormat="@_activeTrendMeta.Format" Width="880" Height="240" />
	}
</OpsModal>

@code {
[Parameter] public string SimId { get; set; } = string.Empty;
[Parameter] public TelemetrySnapshot? Snapshot { get; set; }
[Parameter] public GrainDryerSchematicLayout? Layout { get; set; }

// ── Trend modal state ──
private bool _showTrendModal;
private TrendMeta? _activeTrendMeta;
private double _lastTrendTimeSeconds = double.NaN;
private readonly Dictionary<string, List<LineChart.Point>> _trendHistory = new(StringComparer.OrdinalIgnoreCase);
private const int MaxTrendPoints = 300;

private static class TrendKey
{
	public const string WetBinWeightLb = nameof(WetBinWeightLb);
	public const string InletMoisturePercent = nameof(InletMoisturePercent);
	public const string DryBinWeightLb = nameof(DryBinWeightLb);
	public const string PlenumTempF = nameof(PlenumTempF);
	public const string OutletMoisturePercent = nameof(OutletMoisturePercent);
	public const string GrainHoldUpLb = nameof(GrainHoldUpLb);
	public const string ExhaustTempF = nameof(ExhaustTempF);
	public const string AirflowCfm = nameof(AirflowCfm);
	public const string BurnerOutputPercent = nameof(BurnerOutputPercent);
	public const string FeedRateLbPerSec = nameof(FeedRateLbPerSec);
	public const string DischargeRateLbPerSec = nameof(DischargeRateLbPerSec);
	public const string ResidenceTimeMinutes = nameof(ResidenceTimeMinutes);
}

private sealed record TrendMeta(string Key, string Tag, string Label, string Unit, string Format, Func<GrainDryerSchematic, double> ReadValue);

private static readonly IReadOnlyDictionary<string, TrendMeta> TrendMetrics = new Dictionary<string, TrendMeta>(StringComparer.OrdinalIgnoreCase)
{
	[TrendKey.WetBinWeightLb] = new(TrendKey.WetBinWeightLb, "WT-301", "Wet Bin Weight", "lb", "0", s => s.WetBinWeightLb),
	[TrendKey.InletMoisturePercent] = new(TrendKey.InletMoisturePercent, "MT-301", "Inlet Moisture", "%", "0.0", s => s.InletMoisturePercent),
	[TrendKey.DryBinWeightLb] = new(TrendKey.DryBinWeightLb, "WT-302", "Dry Bin Weight", "lb", "0", s => s.DryBinWeightLb),
	[TrendKey.PlenumTempF] = new(TrendKey.PlenumTempF, "TT-301", "Plenum Temperature", "F", "0.0", s => s.PlenumTempF),
	[TrendKey.OutletMoisturePercent] = new(TrendKey.OutletMoisturePercent, "MT-302", "Outlet Moisture", "%", "0.0", s => s.OutletMoisturePercent),
	[TrendKey.GrainHoldUpLb] = new(TrendKey.GrainHoldUpLb, "HU-301", "Grain Hold-Up", "lb", "0", s => s.GrainHoldUpLb),
	[TrendKey.ExhaustTempF] = new(TrendKey.ExhaustTempF, "TT-302", "Exhaust Temperature", "F", "0.0", s => s.ExhaustTempF),
	[TrendKey.AirflowCfm] = new(TrendKey.AirflowCfm, "AT-301", "Airflow", "cfm", "0", s => s.AirflowCfm),
	[TrendKey.BurnerOutputPercent] = new(TrendKey.BurnerOutputPercent, "BT-301", "Burner Output", "%", "0.0", s => s.BurnerOutputPercent),
	[TrendKey.FeedRateLbPerSec] = new(TrendKey.FeedRateLbPerSec, "FT-301", "Feed Rate", "lb/s", "0.0", s => s.FeedRateLbPerSec),
	[TrendKey.DischargeRateLbPerSec] = new(TrendKey.DischargeRateLbPerSec, "FT-302", "Discharge Rate", "lb/s", "0.0", s => s.DischargeRateLbPerSec),
	[TrendKey.ResidenceTimeMinutes] = new(TrendKey.ResidenceTimeMinutes, "RT-301", "Residence Time", "min", "0.0", s => s.ResidenceTimeMinutes),
};

protected override void OnParametersSet()
{
	CaptureTrendSnapshot();
}

private double GetSignal(string name) => Snapshot?.Signals.TryGetValue(name, out var value) == true ? value : 0.0;
private double GetParameter(string name) => Snapshot?.Parameters.TryGetValue(name, out var value) == true ? value : 0.0;

private bool StartupAutomationEnabled => GetParameter("StartupAutomationEnable") >= 0.5;
private bool ShutdownAutomationEnabled => GetParameter("ShutdownAutomationEnable") >= 0.5;
private bool StartupAutomationActive => GetSignal("StartupAutomationActive") >= 0.5;
private bool ShutdownAutomationActive => GetSignal("ShutdownAutomationActive") >= 0.5;
private bool FeedEnabled => GetParameter("FeedEnable") >= 0.5;
private bool BurnerEnabled => GetParameter("BurnerEnable") >= 0.5;
private bool FanEnabled => GetParameter("FanEnable") >= 0.5;
private bool FeedRunning => GetSignal("FeedRunning") >= 0.5;
private bool BurnerRunning => GetSignal("BurnerRunning") >= 0.5;
private bool FanRunning => GetSignal("FanRunning") >= 0.5;
private bool WetBinEmpty => GetSignal("IsWetBinEmpty") >= 0.5;
private bool DryBinFull => GetSignal("IsDryBinFull") >= 0.5;
private bool HighTempAlarm => GetSignal("IsHighTempAlarm") >= 0.5;
private bool AirflowLowAlarm => GetSignal("IsAirflowLowAlarm") >= 0.5;
private bool FeedPathActive => FeedRunning && !WetBinEmpty;
private bool HeatRunning => BurnerRunning && FanRunning;
private bool DischargeActive => FeedRunning && !DryBinFull;
private bool AnyAlarm => HighTempAlarm || AirflowLowAlarm || WetBinEmpty || DryBinFull;

private double WetBinWeightLb => ClampNonNegative(GetSignal("WetBinWeightLb"));
private double DryBinWeightLb => ClampNonNegative(GetSignal("DryBinWeightLb"));
private double GrainHoldUpLb => ClampNonNegative(GetSignal("GrainHoldUpLb"));
private double DryBinCapacityLb => Math.Max(1.0, GetParameter("DryBinCapacityLb"));
private double WetBinCapacityLb => Math.Max(1.0, Math.Max(GetParameter("WetBinWeightLb"), WetBinWeightLb + GrainHoldUpLb + 1000.0));
private double DryerHoldUpCapacityLb => Math.Max(1.0, GetParameter("DryerHoldUpCapacityLb"));
private double TargetOutletMoisturePercent => GetParameter("TargetOutletMoisturePercent");
private double FeedRateCommandLbPerSec => GetParameter("FeedRateCommandLbPerSec");
private double BurnerFiringRatePercent => GetParameter("BurnerFiringRatePercent");
private double FanSpeedPercent => GetParameter("FanSpeedPercent");
private double OutletMoisturePercent => GetSignal("OutletMoisturePercent");
private double InletMoisturePercent => GetSignal("InletMoisturePercent");
private double MoistureControlErrorPercent => GetSignal("MoistureControlErrorPercent");
private double FeedRateLbPerSec => GetSignal("FeedRateLbPerSec");
private double DischargeRateLbPerSec => GetSignal("DischargeRateLbPerSec");
private double ResidenceTimeMinutes => GetSignal("ResidenceTimeMinutes");
private double AirflowCfm => GetSignal("AirflowCfm");
private double PlenumTempF => GetSignal("PlenumTempF");
private double ExhaustTempF => GetSignal("ExhaustTempF");
private double BurnerOutputPercent => GetSignal("BurnerOutputPercent");
private double MoistureRemovalRateLbPerSec => GetSignal("MoistureRemovalRateLbPerSec");
private double WetFillRatio => Math.Clamp(WetBinWeightLb / WetBinCapacityLb, 0.0, 1.0);
private double DryFillRatio => Math.Clamp(DryBinWeightLb / DryBinCapacityLb, 0.0, 1.0);
private double HoldUpRatio => Math.Clamp(GrainHoldUpLb / DryerHoldUpCapacityLb, 0.0, 1.0);

private string ModeLabel => StartupAutomationActive ? "Startup auto" : ShutdownAutomationActive ? "Shutdown auto" : "Manual control";
private string AutomationLabel => StartupAutomationActive ? "Startup sequence live" : ShutdownAutomationActive ? "Shutdown sequence live" : StartupAutomationEnabled ? "Startup armed" : ShutdownAutomationEnabled ? "Shutdown armed" : "Manual hold";
private string AlarmSummary => AnyAlarm ? $"{ActiveAlarmCount} active" : "Normal";
private int ActiveAlarmCount => (HighTempAlarm ? 1 : 0) + (AirflowLowAlarm ? 1 : 0) + (WetBinEmpty ? 1 : 0) + (DryBinFull ? 1 : 0);
private string AlarmBanner => HighTempAlarm ? "High Temp Alarm" : AirflowLowAlarm ? "Low Airflow Alarm" : WetBinEmpty ? "Wet Bin Empty" : DryBinFull ? "Dry Bin Full" : "Dryer System Normal";

private static string RunningLabel(bool state) => state ? "Running" : "Stopped";
private static double ClampNonNegative(double value) => double.IsFinite(value) ? Math.Max(0.0, value) : 0.0;

// ── Trend helpers ──
private void CaptureTrendSnapshot()
{
	if (Snapshot is null) return;
	var t = Snapshot.TimeSeconds;
	if (!double.IsNaN(_lastTrendTimeSeconds) && Math.Abs(_lastTrendTimeSeconds - t) < 1e-9) return;
	_lastTrendTimeSeconds = t;
	foreach (var m in TrendMetrics.Values)
	{
		if (!_trendHistory.TryGetValue(m.Key, out var pts))
		{
			pts = new List<LineChart.Point>(MaxTrendPoints);
			_trendHistory[m.Key] = pts;
		}
		pts.Add(new LineChart.Point(t, m.ReadValue(this)));
		if (pts.Count > MaxTrendPoints) pts.RemoveRange(0, pts.Count - MaxTrendPoints);
	}
}

private void OpenTrend(string trendKey)
{
	if (!TrendMetrics.TryGetValue(trendKey, out var meta)) return;
	_activeTrendMeta = meta;
	_showTrendModal = true;
}

private Task CloseTrendModalAsync()
{
	_showTrendModal = false;
	return Task.CompletedTask;
}

private LineChart.Point[] GetTrendPoints(string key) =>
	_trendHistory.TryGetValue(key, out var pts) ? pts.ToArray() : Array.Empty<LineChart.Point>();

private string FormatTrendValue(TrendMeta meta)
{
	var v = meta.ReadValue(this);
	return string.IsNullOrWhiteSpace(meta.Unit)
		? v.ToString(meta.Format, CultureInfo.InvariantCulture)
		: $"{v.ToString(meta.Format, CultureInfo.InvariantCulture)} {meta.Unit}";
}
}
