@using System.Globalization
@namespace SkyNet.Simulator.Dashboard.Components
@using SkyNet.Simulator.Contracts

@if (Snapshot is null)
{
	<div class="grain-hmi-shell grain-hmi-shell-empty">
		<div class="grain-hmi-empty">Waiting for telemetry...</div>
	</div>
}
else
{
	var schematicLayout = Layout ?? GrainDryerSchematicLayout.Default;
	var canvasWidth = schematicLayout.CanvasWidth;
	var canvasHeight = schematicLayout.CanvasHeight;
	var wetFillY = F(36.0 + (126.0 * (1.0 - WetFillRatio)));
	var wetFillHeight = F(126.0 * WetFillRatio);
	var holdFillY = F(30.0 + (148.0 * (1.0 - HoldUpRatio)));
	var holdFillHeight = F(148.0 * HoldUpRatio);
	var dryFillY = F(36.0 + (126.0 * (1.0 - DryFillRatio)));
	var dryFillHeight = F(126.0 * DryFillRatio);
	var feedPath = $"M{F(schematicLayout.WetBinX + 156.0)} {F(schematicLayout.WetBinY - 4.0)} L{F(schematicLayout.WetBinX + 156.0)} {F(schematicLayout.DryerColumnY + 78.0)} L{F(schematicLayout.DryerColumnX + 8.0)} {F(schematicLayout.DryerColumnY + 78.0)}";
	var heatPath = $"M{F(schematicLayout.FanModuleX + 132.0)} {F(schematicLayout.FanModuleY + 28.0)} L{F(schematicLayout.FanModuleX + 132.0)} {F(schematicLayout.FanModuleY - 42.0)} L{F(schematicLayout.DryerColumnX + 94.0)} {F(schematicLayout.FanModuleY - 42.0)} L{F(schematicLayout.DryerColumnX + 94.0)} {F(schematicLayout.DryerColumnY + 174.0)}";
	var dischargePath = $"M{F(schematicLayout.DryerColumnX + 268.0)} {F(schematicLayout.DryerColumnY + 78.0)} L{F(schematicLayout.DryBinX + 30.0)} {F(schematicLayout.DryerColumnY + 78.0)} L{F(schematicLayout.DryBinX + 30.0)} {F(schematicLayout.DryBinY - 4.0)}";
	var recyclePath = $"M{F(schematicLayout.DryerColumnX + 230.0)} {F(schematicLayout.DryerColumnY + 174.0)} L{F(schematicLayout.DryerColumnX + 230.0)} {F(schematicLayout.FanModuleY - 42.0)} L{F(schematicLayout.DryBinX - 2.0)} {F(schematicLayout.FanModuleY - 42.0)}";
	var ductTopPath = $"M{F(schematicLayout.WetBinX + 120.0)} {F(schematicLayout.FilterBoxY + 56.0)} L{F(schematicLayout.WetBinX + 120.0)} {F(schematicLayout.FilterBoxY + 18.0)} L{F(schematicLayout.FilterBoxX + 100.0)} {F(schematicLayout.FilterBoxY + 18.0)} L{F(schematicLayout.FilterBoxX + 100.0)} {F(schematicLayout.FilterBoxY + 56.0)}";
	var ductTopPath2 = $"M{F(schematicLayout.ExhaustBoxX - 16.0)} {F(schematicLayout.ExhaustBoxY + 56.0)} L{F(schematicLayout.ExhaustBoxX - 16.0)} {F(schematicLayout.ExhaustBoxY + 18.0)} L{F(schematicLayout.DryBinX + 8.0)} {F(schematicLayout.ExhaustBoxY + 18.0)} L{F(schematicLayout.DryBinX + 8.0)} {F(schematicLayout.ExhaustBoxY + 56.0)}";
	var feedScrewFlights = VerticalFlightPositions(22, 6, 22);
	var dischargeFlights = HorizontalFlightPositions(16, 7, 22);
	var leftBucketX = schematicLayout.WetBinX - 16.0;
	var rightBucketX = schematicLayout.DryBinX + 124.0;
	var bucketStartY = Math.Min(schematicLayout.WetBinY, schematicLayout.DryBinY) - 18.0;

	<section class="grain-hmi-shell">
		<header class="grain-hmi-header">
			<div>
				<p class="grain-hmi-kicker">Area 301 Dryer</p>
				<h3>Grain Dryer Line DR-301</h3>
				<p class="grain-hmi-copy">Operator overview with route state, moisture control, thermal section, and alarm context on one process screen.</p>
			</div>
			<div class="grain-hmi-header-metrics">
				<div>
					<span class="grain-hmi-label">Mode</span>
					<strong>@ModeLabel</strong>
				</div>
				<div>
					<span class="grain-hmi-label">Outlet</span>
					<strong>@OutletMoisturePercent.ToString("0.0", CultureInfo.InvariantCulture)%</strong>
				</div>
				<div>
					<span class="grain-hmi-label">Plenum</span>
					<strong>@PlenumTempF.ToString("0.0", CultureInfo.InvariantCulture) F</strong>
				</div>
				<div>
					<span class="grain-hmi-label">Alarm State</span>
					<strong class="@(AnyAlarm ? "is-alert" : "is-live")">@AlarmSummary</strong>
				</div>
			</div>
		</header>

		<div class="grain-hmi-board">
			<div class="grain-hmi-stage">
				<div class="grain-hmi-tabstrip">
					<button type="button" class="grain-hmi-tab is-active">Overview</button>
					<button type="button" class="grain-hmi-tab">Equipment</button>
					<button type="button" class="grain-hmi-tab">Permissives</button>
					<button type="button" class="grain-hmi-tab">Trends</button>
					<div class="grain-hmi-banner @(AnyAlarm ? "is-alert" : "is-live")">@(AnyAlarm ? AlarmBanner : "System healthy")</div>
				</div>
				<div class="grain-hmi-instrument-row">
					<div class="grain-hmi-meter-card">
						<span class="grain-hmi-label">Target Moisture</span>
						<strong>@TargetOutletMoisturePercent.ToString("0.0", CultureInfo.InvariantCulture)%</strong>
						<small>Error @MoistureControlErrorPercent.ToString("0.0", CultureInfo.InvariantCulture)%</small>
					</div>
					<div class="grain-hmi-meter-card">
						<span class="grain-hmi-label">Airflow</span>
						<strong>@AirflowCfm.ToString("0", CultureInfo.InvariantCulture) cfm</strong>
						<small>Fan @FanSpeedPercent.ToString("0", CultureInfo.InvariantCulture)% speed</small>
					</div>
					<div class="grain-hmi-meter-card">
						<span class="grain-hmi-label">Burner Output</span>
						<strong>@BurnerOutputPercent.ToString("0.0", CultureInfo.InvariantCulture)%</strong>
						<small>Exhaust @ExhaustTempF.ToString("0.0", CultureInfo.InvariantCulture) F</small>
					</div>
					<div class="grain-hmi-meter-card">
						<span class="grain-hmi-label">Throughput</span>
						<strong>@DischargeRateLbPerSec.ToString("0.0", CultureInfo.InvariantCulture) lb/s</strong>
						<small>Residence @ResidenceTimeMinutes.ToString("0.0", CultureInfo.InvariantCulture) min</small>
					</div>
				</div>

				<div class="grain-hmi-scene-wrap">
					<div class="grain-hmi-scene-titlebar">
						<span>DR-301 Process Overview</span>
						<span>Simulation @Snapshot.TimeSeconds.ToString("0.0", CultureInfo.InvariantCulture)s</span>
						<span>@AutomationLabel</span>
					</div>
					<div class="grain-hmi-scene">
						<svg viewBox="@($"0 0 {canvasWidth} {canvasHeight}")" class="grain-hmi-svg">
							<defs>
								<linearGradient id="grain-hmi-bg" x1="0" y1="0" x2="1" y2="1">
									<stop offset="0%" stop-color="#eef2f4" />
									<stop offset="100%" stop-color="#dce3e7" />
								</linearGradient>
								<linearGradient id="grain-hmi-metal" x1="0" y1="0" x2="1" y2="1">
									<stop offset="0%" stop-color="#d9e0e7" />
									<stop offset="100%" stop-color="#8593a7" />
								</linearGradient>
								<linearGradient id="grain-hmi-grain" x1="0" y1="0" x2="0" y2="1">
									<stop offset="0%" stop-color="#efe2a0" />
									<stop offset="100%" stop-color="#ca9d3d" />
								</linearGradient>
								<linearGradient id="grain-hmi-heat" x1="0" y1="0" x2="1" y2="0">
									<stop offset="0%" stop-color="#fff28a" />
									<stop offset="100%" stop-color="#ef7420" />
								</linearGradient>
								<linearGradient id="grain-hmi-glass" x1="0" y1="0" x2="0" y2="1">
									<stop offset="0%" stop-color="#d6f6fb" />
									<stop offset="100%" stop-color="#78b8c2" />
								</linearGradient>
								<filter id="grain-hmi-glow" x="-20%" y="-20%" width="140%" height="140%">
									<feGaussianBlur stdDeviation="4.5" result="blur" />
									<feMerge>
										<feMergeNode in="blur" />
										<feMergeNode in="SourceGraphic" />
									</feMerge>
								</filter>
							</defs>

							<rect x="16" y="16" width="@(canvasWidth - 32.0)" height="@(canvasHeight - 32.0)" rx="8" ry="8" fill="url(#grain-hmi-bg)" stroke="#a8b6bf" stroke-width="1.6" />
							<rect x="46" y="40" width="@(canvasWidth - 92.0)" height="78" rx="4" ry="4" fill="#f6f8f9" stroke="#bcc6cc" stroke-width="1.2" />
							<rect x="46" y="132" width="@(canvasWidth - 92.0)" height="@(canvasHeight - 210.0)" rx="4" ry="4" fill="#eef2f4" stroke="#bcc6cc" stroke-width="1.2" />
							<rect x="60" y="128" width="54" height="@(canvasHeight - 190.0)" rx="4" ry="4" fill="#d5dde1" stroke="#a3b0b8" stroke-width="1.2" />
							<rect x="@(canvasWidth - 114.0)" y="128" width="54" height="@(canvasHeight - 190.0)" rx="4" ry="4" fill="#d5dde1" stroke="#a3b0b8" stroke-width="1.2" />
							@foreach (var bucketY in ElevatorBucketPositions(bucketStartY, 8, 43))
							{
								<g>
									<rect x="@leftBucketX" y="@bucketY" width="18" height="18" rx="2" ry="2" fill="#a413ad" stroke="#5a0b62" stroke-width="1" />
									<rect x="@rightBucketX" y="@bucketY" width="18" height="18" rx="2" ry="2" fill="#a413ad" stroke="#5a0b62" stroke-width="1" />
								</g>
							}
							<path d="@ductTopPath" fill="none" stroke="#9da9b1" stroke-width="8" stroke-linecap="square" />
							<path d="@ductTopPath2" fill="none" stroke="#9da9b1" stroke-width="8" stroke-linecap="square" />
							<g transform="translate(@schematicLayout.FilterBoxX @schematicLayout.FilterBoxY)">
								<rect x="0" y="0" width="86" height="92" rx="10" ry="10" fill="url(#grain-hmi-metal)" stroke="#566476" stroke-width="2" />
								<rect x="16" y="16" width="54" height="42" rx="8" ry="8" fill="#eceef1" stroke="#8a95a4" stroke-width="1.2" />
								<path d="M18 58 L68 58 L56 84 L30 84 Z" fill="#d2d8df" stroke="#5e6d7f" stroke-width="1.2" />
								<circle cx="44" cy="74" r="12" fill="#8fd7e2" stroke="#3d5a73" stroke-width="1.5" />
								<text x="43" y="-5" text-anchor="middle" class="grain-hmi-svg-box-label">Filter Pressure</text>
								<text x="43" y="39" text-anchor="middle" class="grain-hmi-svg-box-value">@AirflowCfm.ToString("0", CultureInfo.InvariantCulture)</text>
							</g>
							<g transform="translate(@schematicLayout.ExhaustBoxX @schematicLayout.ExhaustBoxY)">
								<rect x="0" y="0" width="86" height="92" rx="10" ry="10" fill="url(#grain-hmi-metal)" stroke="#566476" stroke-width="2" />
								<rect x="16" y="16" width="54" height="42" rx="8" ry="8" fill="#eceef1" stroke="#8a95a4" stroke-width="1.2" />
								<path d="M18 58 L68 58 L56 84 L30 84 Z" fill="#d2d8df" stroke="#5e6d7f" stroke-width="1.2" />
								<circle cx="44" cy="74" r="12" fill="#8fd7e2" stroke="#3d5a73" stroke-width="1.5" />
								<text x="43" y="-5" text-anchor="middle" class="grain-hmi-svg-box-label">Exhaust Header</text>
								<text x="43" y="39" text-anchor="middle" class="grain-hmi-svg-box-value">@ExhaustTempF.ToString("0.0", CultureInfo.InvariantCulture) F</text>
							</g>

							<g transform="translate(@schematicLayout.WetBinX @schematicLayout.WetBinY)">
								<rect x="0" y="0" width="122" height="208" rx="18" ry="18" fill="url(#grain-hmi-metal)" stroke="#4e5d74" stroke-width="2" />
								<path d="M24 176 L98 176 L82 226 L40 226 Z" fill="#bcc6cf" stroke="#4e5d74" stroke-width="1.6" />
								<rect x="18" y="36" width="86" height="126" rx="10" ry="10" fill="#f5f8fa" stroke="#73849a" stroke-width="1.6" />
								<rect x="18" y="@wetFillY" width="86" height="@wetFillHeight" rx="10" ry="10" fill="url(#grain-hmi-grain)" opacity="0.94" />
								<text x="61" y="26" text-anchor="middle" class="grain-hmi-svg-title">Wet Bin</text>
								<text x="61" y="194" text-anchor="middle" class="grain-hmi-svg-text">@WetBinWeightLb.ToString("0", CultureInfo.InvariantCulture) lb</text>
								<text x="61" y="212" text-anchor="middle" class="grain-hmi-svg-text">@InletMoisturePercent.ToString("0.0", CultureInfo.InvariantCulture)% moisture</text>
							</g>

							<g transform="translate(@schematicLayout.DryerColumnX @schematicLayout.DryerColumnY)">
								<rect x="0" y="0" width="278" height="266" rx="20" ry="20" fill="url(#grain-hmi-metal)" stroke="#4e5d74" stroke-width="2" />
								<path d="M18 50 L260 50 L234 12 L44 12 Z" fill="#c9d0d7" stroke="#596a7d" stroke-width="1.4" />
								<path d="M36 184 L242 184 L210 258 L68 258 Z" fill="#6db2b8" stroke="#315d63" stroke-width="1.5" opacity="0.94" />
								<rect x="36" y="30" width="206" height="148" rx="12" ry="12" fill="#d5eef3" stroke="#5d7693" stroke-width="1.5" />
								<rect x="36" y="@holdFillY" width="206" height="@holdFillHeight" rx="12" ry="12" fill="url(#grain-hmi-grain)" opacity="0.88" />
								<rect x="24" y="8" width="230" height="28" rx="10" ry="10" fill="@(HeatRunning ? "#ffdd67" : "#8893a8")" opacity="0.92" />
								<rect x="42" y="102" width="194" height="20" rx="4" ry="4" fill="#4cb0bb" stroke="#205a62" stroke-width="1.2" opacity="0.92" />
								<line x1="106" y1="102" x2="106" y2="258" stroke="#2d555c" stroke-width="2" />
								<line x1="170" y1="102" x2="170" y2="258" stroke="#2d555c" stroke-width="2" />
								<circle cx="78" cy="90" r="8" fill="#205c53" stroke="#0b2824" stroke-width="1.4" />
								<circle cx="142" cy="90" r="8" fill="#205c53" stroke="#0b2824" stroke-width="1.4" />
								<rect x="52" y="212" width="174" height="28" rx="8" ry="8" fill="url(#grain-hmi-glass)" stroke="#49627f" stroke-width="1.5" />
								<text x="139" y="25" text-anchor="middle" class="grain-hmi-svg-cap">Plenum @PlenumTempF.ToString("0.0", CultureInfo.InvariantCulture) F</text>
								<text x="139" y="200" text-anchor="middle" class="grain-hmi-svg-title">Drying Column</text>
								<text x="74" y="120" text-anchor="middle" class="grain-hmi-svg-box-label">Zone 1</text>
								<text x="138" y="120" text-anchor="middle" class="grain-hmi-svg-box-label">Zone 2</text>
								<text x="139" y="231" text-anchor="middle" class="grain-hmi-svg-text">Hold-up @GrainHoldUpLb.ToString("0", CultureInfo.InvariantCulture) lb</text>
								<text x="139" y="248" text-anchor="middle" class="grain-hmi-svg-text">Residence @ResidenceTimeMinutes.ToString("0.0", CultureInfo.InvariantCulture) min</text>
							</g>

							<g transform="translate(@schematicLayout.DryBinX @schematicLayout.DryBinY)">
								<rect x="0" y="0" width="122" height="208" rx="18" ry="18" fill="url(#grain-hmi-metal)" stroke="#4e5d74" stroke-width="2" />
								<path d="M24 176 L98 176 L82 226 L40 226 Z" fill="#bcc6cf" stroke="#4e5d74" stroke-width="1.6" />
								<rect x="18" y="36" width="86" height="126" rx="10" ry="10" fill="#f3f8e6" stroke="#73849a" stroke-width="1.6" />
								<rect x="18" y="@dryFillY" width="86" height="@dryFillHeight" rx="10" ry="10" fill="#8fd574" opacity="0.96" />
								<text x="61" y="26" text-anchor="middle" class="grain-hmi-svg-title">Dry Bin</text>
								<text x="61" y="194" text-anchor="middle" class="grain-hmi-svg-text">@DryBinWeightLb.ToString("0", CultureInfo.InvariantCulture) lb</text>
								<text x="61" y="212" text-anchor="middle" class="grain-hmi-svg-text">Cap @DryBinCapacityLb.ToString("0", CultureInfo.InvariantCulture) lb</text>
							</g>

							<g transform="translate(@schematicLayout.FanModuleX @schematicLayout.FanModuleY)">
								<rect x="0" y="0" width="132" height="66" rx="12" ry="12" fill="url(#grain-hmi-metal)" stroke="#4e5d74" stroke-width="2" />
								<circle cx="52" cy="32" r="24" fill="#d5eef3" stroke="#43617d" stroke-width="2" />
								<circle cx="52" cy="32" r="8" fill="#527590" />
								<path d="M52 8 L58 28 L78 32 L58 38 L52 58 L46 38 L26 32 L46 28 Z" fill="#8ad5df" />
								<text x="90" y="30" class="grain-hmi-svg-text">Fan</text>
								<text x="90" y="48" class="grain-hmi-svg-text">@FanSpeedPercent.ToString("0", CultureInfo.InvariantCulture)%</text>
							</g>

							<g transform="translate(@schematicLayout.FeedScrewX @schematicLayout.FeedScrewY)">
								<path d="M20 8 L20 156" stroke="#d4d7d0" stroke-width="18" stroke-linecap="round" />
								<path d="M20 8 L20 156" stroke="#8de7f3" stroke-width="8" stroke-linecap="round" opacity="0.88" />
								<rect x="0" y="14" width="40" height="136" rx="10" ry="10" fill="#67b8bf" stroke="#2e6167" stroke-width="1.8" opacity="0.95" />
								@foreach (var flightY in feedScrewFlights)
								{
									<g>
										<line x1="6" y1="@flightY" x2="34" y2="@(flightY + 12)" stroke="#ecfbff" stroke-width="2" />
										<line x1="34" y1="@flightY" x2="6" y2="@(flightY + 12)" stroke="#2f646a" stroke-width="2" opacity="0.7" />
									</g>
								}
								<rect x="-2" y="0" width="44" height="16" rx="4" ry="4" fill="#9099a4" stroke="#525d6d" stroke-width="1.5" />
								<rect x="-2" y="150" width="44" height="16" rx="4" ry="4" fill="#9099a4" stroke="#525d6d" stroke-width="1.5" />
								<text x="-36" y="24" text-anchor="end" class="grain-hmi-svg-box-label">Feed Screw FS-201</text>
								<text x="-36" y="42" text-anchor="end" class="grain-hmi-svg-text">Command @FeedRateCommandLbPerSec.ToString("0.0", CultureInfo.InvariantCulture) lb/s</text>
							</g>

							<g transform="translate(@schematicLayout.BurnerModuleX @schematicLayout.BurnerModuleY)">
								<rect x="0" y="0" width="132" height="66" rx="12" ry="12" fill="url(#grain-hmi-metal)" stroke="#4e5d74" stroke-width="2" />
								<rect x="20" y="18" width="74" height="22" rx="8" ry="8" fill="#ffdc65" stroke="#935a07" stroke-width="1.4" />
								<text x="56" y="14" text-anchor="middle" class="grain-hmi-svg-text">Burner</text>
								<text x="56" y="58" text-anchor="middle" class="grain-hmi-svg-text">@BurnerOutputPercent.ToString("0.0", CultureInfo.InvariantCulture)%</text>
							</g>

							<g transform="translate(@schematicLayout.FeedModuleX @schematicLayout.FeedModuleY)">
								<rect x="0" y="0" width="132" height="66" rx="12" ry="12" fill="url(#grain-hmi-metal)" stroke="#4e5d74" stroke-width="2" />
								<circle cx="50" cy="32" r="24" fill="#d5eef3" stroke="#43617d" stroke-width="2" />
								<path d="M50 8 L56 28 L76 32 L56 38 L50 58 L44 38 L24 32 L44 28 Z" fill="#8ad5df" />
								<text x="88" y="30" class="grain-hmi-svg-text">Feed</text>
								<text x="88" y="48" class="grain-hmi-svg-text">@FeedRateLbPerSec.ToString("0.0", CultureInfo.InvariantCulture) lb/s</text>
							</g>

							<g transform="translate(@schematicLayout.DischargeConveyorX @schematicLayout.DischargeConveyorY)">
								<path d="M-6 20 L186 20" stroke="#d4d7d0" stroke-width="18" stroke-linecap="round" />
								<path d="M-6 20 L186 20" stroke="#59ff4a" stroke-width="8" stroke-linecap="round" opacity="0.84" />
								<rect x="0" y="0" width="180" height="40" rx="8" ry="8" fill="#89f768" stroke="#1d7a16" stroke-width="1.8" opacity="0.94" />
								@foreach (var flightX in dischargeFlights)
								{
									<g>
										<line x1="@flightX" y1="6" x2="@(flightX + 10)" y2="34" stroke="#ecfff0" stroke-width="2" />
										<line x1="@(flightX + 10)" y1="6" x2="@flightX" y2="34" stroke="#2c7a22" stroke-width="2" opacity="0.72" />
									</g>
								}
								<rect x="-14" y="-2" width="16" height="44" rx="4" ry="4" fill="#9099a4" stroke="#525d6d" stroke-width="1.5" />
								<rect x="180" y="-2" width="16" height="44" rx="4" ry="4" fill="#9099a4" stroke="#525d6d" stroke-width="1.5" />
								<text x="4" y="-8" class="grain-hmi-svg-box-label">Discharge Conveyor DC-301</text>
								<text x="4" y="54" class="grain-hmi-svg-text">@DischargeRateLbPerSec.ToString("0.0", CultureInfo.InvariantCulture) lb/s</text>
							</g>

							<g style="color:@(FeedPathActive ? "#d9d7c7" : "#7b8699")">
								<path d="@feedPath" fill="none" stroke="currentColor" stroke-width="18" opacity="0.28" filter="url(#grain-hmi-glow)" />
								<path d="@feedPath" fill="none" stroke="#d5d3c0" stroke-width="10" stroke-linecap="round" />
							</g>
							<g style="color:@(HeatRunning ? "#ffab32" : "#6b7690")">
								<path d="@heatPath" fill="none" stroke="currentColor" stroke-width="16" opacity="0.34" filter="url(#grain-hmi-glow)" />
								<path d="@heatPath" fill="none" stroke="url(#grain-hmi-heat)" stroke-width="9" stroke-linecap="round" />
							</g>
							<g style="color:@(DischargeActive ? "#d9d7c7" : "#7b8699")">
								<path d="@dischargePath" fill="none" stroke="currentColor" stroke-width="18" opacity="0.28" filter="url(#grain-hmi-glow)" />
								<path d="@dischargePath" fill="none" stroke="#d5d3c0" stroke-width="10" stroke-linecap="round" />
							</g>
							<g style="color:@(HeatRunning ? "#49d8ff" : "#5f6c87")">
								<path d="@recyclePath" fill="none" stroke="currentColor" stroke-width="14" opacity="0.24" filter="url(#grain-hmi-glow)" />
								<path d="@recyclePath" fill="none" stroke="#86dcff" stroke-width="7" stroke-linecap="round" />
							</g>

							<rect x="86" y="62" width="120" height="42" rx="8" ry="8" fill="#7d8598" stroke="#d0d7e6" stroke-width="1.5" />
							<rect x="238" y="62" width="120" height="42" rx="8" ry="8" fill="#7d8598" stroke="#d0d7e6" stroke-width="1.5" />
							<rect x="390" y="62" width="128" height="42" rx="8" ry="8" fill="#7d8598" stroke="#d0d7e6" stroke-width="1.5" />
							<rect x="552" y="62" width="128" height="42" rx="8" ry="8" fill="#7d8598" stroke="#d0d7e6" stroke-width="1.5" />
							<rect x="714" y="62" width="128" height="42" rx="8" ry="8" fill="#7d8598" stroke="#d0d7e6" stroke-width="1.5" />
							<text x="146" y="80" text-anchor="middle" class="grain-hmi-svg-box-label">Trending</text>
							<text x="146" y="96" text-anchor="middle" class="grain-hmi-svg-box-value">Feed @FeedRateLbPerSec.ToString("0.0", CultureInfo.InvariantCulture)</text>
							<text x="298" y="80" text-anchor="middle" class="grain-hmi-svg-box-label">Dryer Gauges</text>
							<text x="298" y="96" text-anchor="middle" class="grain-hmi-svg-box-value">Hold @GrainHoldUpLb.ToString("0", CultureInfo.InvariantCulture)</text>
							<text x="454" y="80" text-anchor="middle" class="grain-hmi-svg-box-label">Moisture</text>
							<text x="454" y="96" text-anchor="middle" class="grain-hmi-svg-box-value">@OutletMoisturePercent.ToString("0.0", CultureInfo.InvariantCulture)%</text>
							<text x="616" y="80" text-anchor="middle" class="grain-hmi-svg-box-label">Airflow</text>
							<text x="616" y="96" text-anchor="middle" class="grain-hmi-svg-box-value">@AirflowCfm.ToString("0", CultureInfo.InvariantCulture) cfm</text>
							<text x="778" y="80" text-anchor="middle" class="grain-hmi-svg-box-label">Exhaust</text>
							<text x="778" y="96" text-anchor="middle" class="grain-hmi-svg-box-value">@ExhaustTempF.ToString("0.0", CultureInfo.InvariantCulture) F</text>
							<rect x="320" y="438" width="252" height="24" rx="3" ry="3" fill="@(AnyAlarm ? "#c8352e" : "#68b84c")" stroke="@(AnyAlarm ? "#7a1c18" : "#355f26")" stroke-width="1" />
							<text x="446" y="454" text-anchor="middle" class="grain-hmi-svg-alert is-banner">@(AnyAlarm ? AlarmBanner.ToUpperInvariant() : "LOCAL DISCONNECT OFF")</text>

							<rect x="720" y="520" width="242" height="44" rx="3" ry="3" fill="#b80d0d" stroke="#ff4b4b" stroke-width="1.5" opacity="@(AnyAlarm ? "1" : "0.35")" />
							<text x="841" y="547" text-anchor="middle" class="grain-hmi-svg-alarm">@AlarmBanner</text>
						</svg>
					</div>

					<div class="grain-hmi-status-grid">
						<section class="grain-hmi-status-card">
							<div class="grain-hmi-status-head">
								<h4>Dryer Control Panel</h4>
								<span>Input</span>
								<span>Output</span>
							</div>
							<div class="grain-hmi-status-row">
								<span>Feed system</span>
								<span class="grain-hmi-status-dot @(FeedEnabled ? "is-live" : string.Empty)"></span>
								<span class="grain-hmi-status-dot @(FeedRunning ? "is-live" : string.Empty)"></span>
							</div>
							<div class="grain-hmi-status-row">
								<span>Burner train</span>
								<span class="grain-hmi-status-dot @(BurnerEnabled ? "is-live" : string.Empty)"></span>
								<span class="grain-hmi-status-dot @(BurnerRunning ? "is-live" : string.Empty)"></span>
							</div>
							<div class="grain-hmi-status-row">
								<span>Fan circuit</span>
								<span class="grain-hmi-status-dot @(FanEnabled ? "is-live" : string.Empty)"></span>
								<span class="grain-hmi-status-dot @(FanRunning ? "is-live" : string.Empty)"></span>
							</div>
							<div class="grain-hmi-status-row">
								<span>Automation state</span>
								<span class="grain-hmi-status-dot @((StartupAutomationEnabled || ShutdownAutomationEnabled) ? "is-live" : string.Empty)"></span>
								<span class="grain-hmi-status-text">@AutomationLabel</span>
							</div>
						</section>

						<section class="grain-hmi-status-card">
							<div class="grain-hmi-status-head">
								<h4>Dryer Quality Panel</h4>
								<span>Setpoint</span>
								<span>Actual</span>
							</div>
							<div class="grain-hmi-status-row">
								<span>Outlet moisture</span>
								<span>@TargetOutletMoisturePercent.ToString("0.0", CultureInfo.InvariantCulture)%</span>
								<span>@OutletMoisturePercent.ToString("0.0", CultureInfo.InvariantCulture)%</span>
							</div>
							<div class="grain-hmi-status-row">
								<span>Feed rate</span>
								<span>@FeedRateCommandLbPerSec.ToString("0.0", CultureInfo.InvariantCulture)</span>
								<span>@FeedRateLbPerSec.ToString("0.0", CultureInfo.InvariantCulture)</span>
							</div>
							<div class="grain-hmi-status-row">
								<span>Burner rate</span>
								<span>@BurnerFiringRatePercent.ToString("0", CultureInfo.InvariantCulture)%</span>
								<span>@BurnerOutputPercent.ToString("0.0", CultureInfo.InvariantCulture)%</span>
							</div>
							<div class="grain-hmi-status-row">
								<span>Moisture removal</span>
								<span>Target</span>
								<span>@MoistureRemovalRateLbPerSec.ToString("0.00", CultureInfo.InvariantCulture) lb/s</span>
							</div>
						</section>
					</div>
				</div>
			</div>

			<div class="grain-hmi-lower-grid">
				<aside class="grain-hmi-nav grain-hmi-nav-inline">
					<button type="button" class="grain-hmi-nav-button">Home</button>
					<button type="button" class="grain-hmi-nav-button">Batching</button>
					<button type="button" class="grain-hmi-nav-button is-active">Dryer</button>
					<button type="button" class="grain-hmi-nav-button">Cooler</button>
					<button type="button" class="grain-hmi-nav-button">Final Process</button>
					<button type="button" class="grain-hmi-nav-button grain-hmi-nav-button-accent">Equipment Status</button>
					<button type="button" class="grain-hmi-nav-button grain-hmi-nav-button-accent">System Parameters</button>
				</aside>

				<aside class="grain-hmi-rack">
				<section class="grain-hmi-panel">
					<div class="grain-hmi-panel-head">
						<h4>Drive Rack</h4>
						<span class="grain-hmi-tag">Status</span>
					</div>
					<div class="grain-hmi-lamp-bank">
						<div class="grain-hmi-lamp-row">
							<span class="grain-hmi-lamp @(FanRunning ? "is-live" : string.Empty)"></span>
							<div>
								<span class="grain-hmi-label">Fan</span>
								<strong>@RunningLabel(FanRunning)</strong>
							</div>
						</div>
						<div class="grain-hmi-lamp-row">
							<span class="grain-hmi-lamp @(BurnerRunning ? "is-live" : string.Empty)"></span>
							<div>
								<span class="grain-hmi-label">Burner</span>
								<strong>@RunningLabel(BurnerRunning)</strong>
							</div>
						</div>
						<div class="grain-hmi-lamp-row">
							<span class="grain-hmi-lamp @(FeedRunning ? "is-live" : string.Empty)"></span>
							<div>
								<span class="grain-hmi-label">Feed</span>
								<strong>@RunningLabel(FeedRunning)</strong>
							</div>
						</div>
					</div>
				</section>

				<section class="grain-hmi-panel">
					<div class="grain-hmi-panel-head">
						<h4>Process Gauges</h4>
						<span class="grain-hmi-tag">Live</span>
					</div>
					<div class="grain-hmi-display-stack">
						<div class="grain-hmi-display-card">
							<span class="grain-hmi-label">Plenum Temp</span>
							<strong>@PlenumTempF.ToString("0.0", CultureInfo.InvariantCulture) F</strong>
						</div>
						<div class="grain-hmi-display-card">
							<span class="grain-hmi-label">Airflow</span>
							<strong>@AirflowCfm.ToString("0", CultureInfo.InvariantCulture) cfm</strong>
						</div>
						<div class="grain-hmi-display-card">
							<span class="grain-hmi-label">Exhaust</span>
							<strong>@ExhaustTempF.ToString("0.0", CultureInfo.InvariantCulture) F</strong>
						</div>
						<div class="grain-hmi-display-card">
							<span class="grain-hmi-label">Removal</span>
							<strong>@MoistureRemovalRateLbPerSec.ToString("0.00", CultureInfo.InvariantCulture) lb/s</strong>
						</div>
					</div>
				</section>

				<section class="grain-hmi-panel">
					<div class="grain-hmi-panel-head">
						<h4>Alarm Lamps</h4>
						<span class="grain-hmi-tag">Annunciator</span>
					</div>
					<div class="grain-hmi-lamp-bank">
						<div class="grain-hmi-lamp-row">
							<span class="grain-hmi-lamp @(HighTempAlarm ? "is-alert" : string.Empty)"></span>
							<div>
								<span class="grain-hmi-label">High Temp</span>
								<strong>@(HighTempAlarm ? "Active" : "Normal")</strong>
							</div>
						</div>
						<div class="grain-hmi-lamp-row">
							<span class="grain-hmi-lamp @(AirflowLowAlarm ? "is-alert" : string.Empty)"></span>
							<div>
								<span class="grain-hmi-label">Low Airflow</span>
								<strong>@(AirflowLowAlarm ? "Active" : "Normal")</strong>
							</div>
						</div>
						<div class="grain-hmi-lamp-row">
							<span class="grain-hmi-lamp @(WetBinEmpty ? "is-alert" : string.Empty)"></span>
							<div>
								<span class="grain-hmi-label">Wet Bin</span>
								<strong>@(WetBinEmpty ? "Empty" : "Available")</strong>
							</div>
						</div>
						<div class="grain-hmi-lamp-row">
							<span class="grain-hmi-lamp @(DryBinFull ? "is-alert" : string.Empty)"></span>
							<div>
								<span class="grain-hmi-label">Dry Bin</span>
								<strong>@(DryBinFull ? "Full" : "Receiving")</strong>
							</div>
						</div>
					</div>
				</section>
				</aside>
			</div>
		</div>

		<footer class="grain-hmi-footer">
			<div class="grain-hmi-console-pill">
				<span class="grain-hmi-label">Wet Inventory</span>
				<strong>@WetBinWeightLb.ToString("0", CultureInfo.InvariantCulture) lb</strong>
			</div>
			<div class="grain-hmi-console-pill">
				<span class="grain-hmi-label">Dry Inventory</span>
				<strong>@DryBinWeightLb.ToString("0", CultureInfo.InvariantCulture) lb</strong>
			</div>
			<div class="grain-hmi-console-pill @(AnyAlarm ? "is-alert" : string.Empty)">
				<span class="grain-hmi-label">Annunciator</span>
				<strong>@AlarmSummary</strong>
			</div>
		</footer>
	</section>
}

@code {
	[Parameter] public string SimId { get; set; } = string.Empty;
	[Parameter] public TelemetrySnapshot? Snapshot { get; set; }
	[Parameter] public GrainDryerSchematicLayout? Layout { get; set; }

	private double GetSignal(string name) => Snapshot?.Signals.TryGetValue(name, out var value) == true ? value : 0.0;
	private double GetParameter(string name) => Snapshot?.Parameters.TryGetValue(name, out var value) == true ? value : 0.0;

	private bool StartupAutomationEnabled => GetParameter("StartupAutomationEnable") >= 0.5;
	private bool ShutdownAutomationEnabled => GetParameter("ShutdownAutomationEnable") >= 0.5;
	private bool StartupAutomationActive => GetSignal("StartupAutomationActive") >= 0.5;
	private bool ShutdownAutomationActive => GetSignal("ShutdownAutomationActive") >= 0.5;
	private bool FeedEnabled => GetParameter("FeedEnable") >= 0.5;
	private bool BurnerEnabled => GetParameter("BurnerEnable") >= 0.5;
	private bool FanEnabled => GetParameter("FanEnable") >= 0.5;
	private bool FeedRunning => GetSignal("FeedRunning") >= 0.5;
	private bool BurnerRunning => GetSignal("BurnerRunning") >= 0.5;
	private bool FanRunning => GetSignal("FanRunning") >= 0.5;
	private bool WetBinEmpty => GetSignal("IsWetBinEmpty") >= 0.5;
	private bool DryBinFull => GetSignal("IsDryBinFull") >= 0.5;
	private bool HighTempAlarm => GetSignal("IsHighTempAlarm") >= 0.5;
	private bool AirflowLowAlarm => GetSignal("IsAirflowLowAlarm") >= 0.5;
	private bool FeedPathActive => FeedRunning && !WetBinEmpty;
	private bool HeatRunning => BurnerRunning && FanRunning;
	private bool DischargeActive => FeedRunning && !DryBinFull;
	private bool AnyAlarm => HighTempAlarm || AirflowLowAlarm || WetBinEmpty || DryBinFull;

	private double WetBinWeightLb => ClampNonNegative(GetSignal("WetBinWeightLb"));
	private double DryBinWeightLb => ClampNonNegative(GetSignal("DryBinWeightLb"));
	private double GrainHoldUpLb => ClampNonNegative(GetSignal("GrainHoldUpLb"));
	private double DryBinCapacityLb => Math.Max(1.0, GetParameter("DryBinCapacityLb"));
	private double WetBinCapacityLb => Math.Max(1.0, Math.Max(GetParameter("WetBinWeightLb"), WetBinWeightLb + GrainHoldUpLb + 1000.0));
	private double DryerHoldUpCapacityLb => Math.Max(1.0, GetParameter("DryerHoldUpCapacityLb"));
	private double TargetOutletMoisturePercent => GetParameter("TargetOutletMoisturePercent");
	private double FeedRateCommandLbPerSec => GetParameter("FeedRateCommandLbPerSec");
	private double BurnerFiringRatePercent => GetParameter("BurnerFiringRatePercent");
	private double FanSpeedPercent => GetParameter("FanSpeedPercent");
	private double OutletMoisturePercent => GetSignal("OutletMoisturePercent");
	private double InletMoisturePercent => GetSignal("InletMoisturePercent");
	private double MoistureControlErrorPercent => GetSignal("MoistureControlErrorPercent");
	private double FeedRateLbPerSec => GetSignal("FeedRateLbPerSec");
	private double DischargeRateLbPerSec => GetSignal("DischargeRateLbPerSec");
	private double ResidenceTimeMinutes => GetSignal("ResidenceTimeMinutes");
	private double AirflowCfm => GetSignal("AirflowCfm");
	private double PlenumTempF => GetSignal("PlenumTempF");
	private double ExhaustTempF => GetSignal("ExhaustTempF");
	private double BurnerOutputPercent => GetSignal("BurnerOutputPercent");
	private double MoistureRemovalRateLbPerSec => GetSignal("MoistureRemovalRateLbPerSec");
	private double WetFillRatio => Math.Clamp(WetBinWeightLb / WetBinCapacityLb, 0.0, 1.0);
	private double DryFillRatio => Math.Clamp(DryBinWeightLb / DryBinCapacityLb, 0.0, 1.0);
	private double HoldUpRatio => Math.Clamp(GrainHoldUpLb / DryerHoldUpCapacityLb, 0.0, 1.0);

	private string ModeLabel => StartupAutomationActive ? "Startup auto" : ShutdownAutomationActive ? "Shutdown auto" : "Manual control";
	private string AutomationLabel => StartupAutomationActive ? "Startup sequence live" : ShutdownAutomationActive ? "Shutdown sequence live" : ShutdownAutomationEnabled ? "Startup armed" : ShutdownAutomationEnabled ? "Shutdown armed" : "Manual hold";
	private string AlarmSummary => AnyAlarm ? $"{ActiveAlarmCount} active" : "Normal";
	private int ActiveAlarmCount => (HighTempAlarm ? 1 : 0) + (AirflowLowAlarm ? 1 : 0) + (WetBinEmpty ? 1 : 0) + (DryBinFull ? 1 : 0);
	private string AlarmBanner => HighTempAlarm ? "High Temp Alarm" : AirflowLowAlarm ? "Low Airflow Alarm" : WetBinEmpty ? "Wet Bin Empty" : DryBinFull ? "Dry Bin Full" : "Dryer System Normal";

	private static string RunningLabel(bool state) => state ? "Running" : "Stopped";
	private static double ClampNonNegative(double value) => double.IsFinite(value) ? Math.Max(0.0, value) : 0.0;
	private static string F(double value) => value.ToString("0.###", CultureInfo.InvariantCulture);
	private static IEnumerable<double> ElevatorBucketPositions(double startY, int count, double spacing) =>
		Enumerable.Range(0, count).Select(index => startY + (index * spacing));
	private static IEnumerable<double> HorizontalFlightPositions(double startX, int count, double spacing) =>
		Enumerable.Range(0, count).Select(index => startX + (index * spacing));
	private static IEnumerable<double> VerticalFlightPositions(double startY, int count, double spacing) =>
		Enumerable.Range(0, count).Select(index => startY + (index * spacing));
}
