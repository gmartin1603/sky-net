@using System.Globalization
@namespace SkyNet.Simulator.Dashboard.Components
@using SkyNet.Simulator.Contracts

@if (Snapshot is null)
{
<div class="grain-hmi-shell grain-hmi-shell-empty">
<div class="grain-hmi-empty">Waiting for telemetry...</div>
</div>
}
else
{
var schematicLayout = Layout ?? GrainDryerSchematicLayout.Default;
var canvasWidth = schematicLayout.CanvasWidth.ToString("0.#", CultureInfo.InvariantCulture);
var canvasHeight = schematicLayout.CanvasHeight.ToString("0.#", CultureInfo.InvariantCulture);

var scadaW = schematicLayout.CanvasWidth;
var scadaH = schematicLayout.CanvasHeight;
var alarmBannerH = 64.0;
var tabBarH = 28.0;
var titleBarH = 34.0;
var statusBarH = 24.0;
var sidebarW = 200.0;
var processTop = alarmBannerH + tabBarH + titleBarH;
var processH = scadaH - processTop - statusBarH;
var processW = scadaW - sidebarW;

var tankW = 90.0;
var tankH = 160.0;
var tankR = 6.0;

var wetX = 70.0;
var wetY = processTop + 70.0;
var wetCX = wetX + tankW / 2.0;
var wetBotY = wetY + tankH;
var wetFillH = Math.Max(0.0, tankH * WetFillRatio);

var dryerX = 280.0;
var dryerY = processTop + 50.0;
var dryerW = 200.0;
var dryerH = 250.0;
var dryerCX = dryerX + dryerW / 2.0;
var dryerBotY = dryerY + dryerH;
var holdFillH = Math.Max(0.0, (dryerH * 0.55) * HoldUpRatio);

var dryX = 590.0;
var dryY = processTop + 70.0;
var dryCX = dryX + tankW / 2.0;
var dryBotY = dryY + tankH;
var dryFillH = Math.Max(0.0, tankH * DryFillRatio);

var fanCX = 140.0;
var fanCY = processTop + 500.0;
var fanR = 24.0;
var fanMotorX = fanCX + 38.0;
var fanMotorY = fanCY - 16.0;

var burnerX = 280.0;
var burnerY = processTop + 478.0;
var burnerW = 120.0;
var burnerH = 44.0;
var burnerMotorX = burnerX + burnerW + 8.0;
var burnerMotorY = burnerY + 6.0;

var feedCX = 540.0;
var feedCY = processTop + 500.0;
var feedR = 24.0;
var feedMotorX = feedCX + 38.0;
var feedMotorY = feedCY - 16.0;

var convX = 340.0;
var convY = processTop + 620.0;
var convW = 200.0;
var convH = 30.0;

var materialColor = FeedPathActive ? "#c8a030" : "#606060";
var heatColor = HeatRunning ? "#e06020" : "#606060";
var dischargeColor = DischargeActive ? "#80b050" : "#606060";
var airColor = FanRunning ? "#0070c0" : "#606060";
var pipeW = 3.0;

var feedJunctionY = wetBotY + 30.0;
var dischJunctionY = dryerY + 80.0;

var selPanelX = processW - 180.0;
var selPanelY = processTop + 10.0;

<section class="grain-hmi-shell scada-industrial">
<div class="scada-canvas-wrap">
<svg viewBox="@($"0 0 {canvasWidth} {canvasHeight}")" class="scada-svg" xmlns="http://www.w3.org/2000/svg">
<defs>
<linearGradient id="scada-tank-shell" x1="0" y1="0" x2="1" y2="0">
<stop offset="0%" stop-color="#b0b0b0" />
<stop offset="30%" stop-color="#d8d8d8" />
<stop offset="70%" stop-color="#e8e8e8" />
<stop offset="100%" stop-color="#c0c0c0" />
</linearGradient>
<linearGradient id="scada-grain-fill" x1="0" y1="0" x2="0" y2="1">
<stop offset="0%" stop-color="#e8d470" />
<stop offset="100%" stop-color="#c8a030" />
</linearGradient>
<linearGradient id="scada-dry-fill" x1="0" y1="0" x2="0" y2="1">
<stop offset="0%" stop-color="#b8d870" />
<stop offset="100%" stop-color="#88b040" />
</linearGradient>
<linearGradient id="scada-motor-run" x1="0" y1="0" x2="0" y2="1">
<stop offset="0%" stop-color="#4caf50" />
<stop offset="100%" stop-color="#2e7d32" />
</linearGradient>
<linearGradient id="scada-motor-off" x1="0" y1="0" x2="0" y2="1">
<stop offset="0%" stop-color="#909090" />
<stop offset="100%" stop-color="#686868" />
</linearGradient>
<linearGradient id="scada-alarm-bar" x1="0" y1="0" x2="0" y2="1">
<stop offset="0%" stop-color="#1a1a2e" />
<stop offset="100%" stop-color="#0d0d1a" />
</linearGradient>
<clipPath id="wet-clip">
<rect x="@(wetX + 2)" y="@(wetY + 2)" width="@(tankW - 4)" height="@(tankH - 4)" rx="@(tankR - 1)" />
</clipPath>
<clipPath id="dry-clip">
<rect x="@(dryX + 2)" y="@(dryY + 2)" width="@(tankW - 4)" height="@(tankH - 4)" rx="@(tankR - 1)" />
</clipPath>
<clipPath id="dryer-clip">
<rect x="@(dryerX + 20)" y="@(dryerY + 60)" width="@(dryerW - 40)" height="@(dryerH * 0.55)" rx="4" />
</clipPath>
</defs>

@* ═══════ ALARM BANNER ═══════ *@
<rect x="0" y="0" width="@scadaW" height="@alarmBannerH" fill="url(#scada-alarm-bar)" />
<line x1="0" y1="@alarmBannerH" x2="@scadaW" y2="@alarmBannerH" stroke="#444" stroke-width="1" />
<g transform="translate(12, 8)">
<rect x="0" y="0" width="24" height="18" rx="3" fill="#333" stroke="#555" stroke-width="0.8" />
<text x="12" y="13" text-anchor="middle" style="fill:#ffc107;font:bold 10px monospace;">⚠</text>
<text x="30" y="13" style="fill:#aaa;font:600 9px 'Segoe UI',sans-serif;">@(AnyAlarm ? ActiveAlarmCount.ToString() : "0")</text>
</g>
<g transform="translate(70, 8)">
<rect x="0" y="0" width="18" height="18" rx="3" fill="@(AnyAlarm ? "#c62828" : "#333")" stroke="#555" stroke-width="0.8" />
<text x="9" y="13" text-anchor="middle" style="fill:#fff;font:bold 8px monospace;">!</text>
</g>
<text x="100" y="18" style="fill:#999;font:600 8px 'Consolas',monospace;letter-spacing:0.02em;">DATE/TIME</text>
<text x="260" y="18" style="fill:#999;font:600 8px 'Consolas',monospace;letter-spacing:0.02em;">TAG</text>
<text x="460" y="18" style="fill:#999;font:600 8px 'Consolas',monospace;letter-spacing:0.02em;">DESCRIPTION</text>
<text x="700" y="18" style="fill:#999;font:600 8px 'Consolas',monospace;letter-spacing:0.02em;">PRIORITY</text>
<line x1="96" y1="22" x2="@(scadaW - 10)" y2="22" stroke="#444" stroke-width="0.5" />
@if (AnyAlarm)
{
var alarmColor = HighTempAlarm ? "#ff6659" : "#ffab40";
var alarmTag = HighTempAlarm ? "DR301_HiTemp" : AirflowLowAlarm ? "DR301_LoAir" : WetBinEmpty ? "WB301_Empty" : "DB301_Full";
<rect x="96" y="26" width="@(scadaW - 106)" height="14" fill="rgba(198,40,40,0.15)" />
<g><text x="100" y="36" style="fill:@alarmColor;font:600 9px 'Consolas',monospace;">@DateTime.Now.ToString("dd/M/yyyy  hh:mm:ss tt")</text></g>
<g><text x="260" y="36" style="fill:@alarmColor;font:600 9px 'Consolas',monospace;">@alarmTag</text></g>
<g><text x="460" y="36" style="fill:@alarmColor;font:600 9px 'Consolas',monospace;">@AlarmBanner</text></g>
<g><text x="700" y="36" style="fill:@alarmColor;font:bold 9px 'Consolas',monospace;">@(HighTempAlarm ? "HH" : "LO")</text></g>
}
else
{
<g><text x="100" y="36" style="fill:#666;font:600 9px 'Consolas',monospace;">(no active alarms)</text></g>
}

@* ═══════ TAB BAR ═══════ *@
<rect x="0" y="@alarmBannerH" width="@scadaW" height="@tabBarH" fill="#008000" />
<line x1="0" y1="@(alarmBannerH + tabBarH)" x2="@scadaW" y2="@(alarmBannerH + tabBarH)" stroke="#004d00" stroke-width="1" />
@{
var tabs = new[] { ("GrainDryer_DR301", true), ("ThermalSection", false), ("FeedControl", false), ("Permissives", false), ("AlarmHistory", false) };
var tabX = 24.0;
}
@foreach (var (tabName, isActive) in tabs)
{
var tw = tabName.Length * 7.2 + 24;
var tabFill = isActive ? "#c0c0c0" : "#009900";
var tabStroke = isActive ? "#888" : "#006600";
var tabTextColor = isActive ? "#000" : "#fff";
<rect x="@tabX" y="@(alarmBannerH + 4)" width="@tw" height="@(tabBarH - 6)" rx="3" fill="@tabFill" stroke="@tabStroke" stroke-width="0.8" />
<g><text x="@(tabX + tw / 2)" y="@(alarmBannerH + 18)" text-anchor="middle" style="fill:@tabTextColor;font:600 9px 'Segoe UI',Tahoma,sans-serif;">@tabName</text></g>
tabX += tw + 4;
}

@* ═══════ TITLE BAR ═══════ *@
<rect x="0" y="@(alarmBannerH + tabBarH)" width="@processW" height="@titleBarH" fill="#e8e8e8" stroke="#aaa" stroke-width="0.5" />
<rect x="@((processW - 360) / 2)" y="@(alarmBannerH + tabBarH + 4)" width="360" height="@(titleBarH - 8)" rx="2" fill="#fff" stroke="#000" stroke-width="1.5" />
<text x="@(processW / 2)" y="@(alarmBannerH + tabBarH + 24)" text-anchor="middle" style="fill:#000;font:bold 15px 'Segoe UI',Tahoma,sans-serif;letter-spacing:0.06em;">GRAIN DRYER LINE DR-301</text>

@* ═══════ PROCESS AREA ═══════ *@
<rect x="0" y="@processTop" width="@processW" height="@processH" fill="#c0c0c0" />

@* ═══════ AUTOMATION MODE PANEL ═══════ *@
<rect x="@selPanelX" y="@selPanelY" width="170" height="56" rx="3" fill="#e0e0e0" stroke="#888" stroke-width="1" />
<text x="@(selPanelX + 8)" y="@(selPanelY + 14)" style="fill:#000;font:bold 9px 'Segoe UI',sans-serif;">Automation Mode</text>
<line x1="@selPanelX" y1="@(selPanelY + 20)" x2="@(selPanelX + 170)" y2="@(selPanelY + 20)" stroke="#aaa" stroke-width="0.5" />
<text x="@(selPanelX + 8)" y="@(selPanelY + 36)" style="fill:#000;font:600 8px 'Segoe UI',sans-serif;">@AutomationLabel</text>
<rect x="@(selPanelX + 8)" y="@(selPanelY + 40)" width="154" height="10" rx="2" fill="@(StartupAutomationActive || ShutdownAutomationActive ? "#4caf50" : "#808080")" />

@* ═══════ WET BIN WB-301 ═══════ *@
<g class="scada-equipment">
<rect x="@wetX" y="@wetY" width="@tankW" height="@tankH" rx="@tankR" fill="url(#scada-tank-shell)" stroke="#555" stroke-width="1.5" />
@if (wetFillH > 0)
{
<rect x="@(wetX + 2)" y="@(wetBotY - wetFillH)" width="@(tankW - 4)" height="@wetFillH" fill="url(#scada-grain-fill)" clip-path="url(#wet-clip)" opacity="0.88" />
}
<line x1="@wetX" y1="@wetY" x2="@(wetX + tankW)" y2="@wetY" stroke="#555" stroke-width="2" />
<line x1="@(wetX + 6)" y1="@(wetY + 4)" x2="@(wetX + 6)" y2="@(wetBotY - 4)" stroke="rgba(255,255,255,0.5)" stroke-width="1.5" />
<line x1="@(wetX - 8)" y1="@wetY" x2="@(wetX - 3)" y2="@wetY" stroke="#333" stroke-width="1" />
<text x="@(wetX - 12)" y="@(wetY + 3)" text-anchor="end" style="fill:#000;font:600 7px 'Segoe UI',sans-serif;">HH</text>
<line x1="@(wetX - 8)" y1="@wetBotY" x2="@(wetX - 3)" y2="@wetBotY" stroke="#333" stroke-width="1" />
<text x="@(wetX - 12)" y="@(wetBotY + 3)" text-anchor="end" style="fill:#000;font:600 7px 'Segoe UI',sans-serif;">LL</text>
@if (WetBinEmpty)
{
<circle cx="@(wetX - 16)" cy="@(wetBotY - 8)" r="5" fill="#c62828" stroke="#fff" stroke-width="0.5">
<animate attributeName="opacity" values="1;0.3;1" dur="1s" repeatCount="indefinite" />
</circle>
}
<text x="@wetCX" y="@(wetBotY + 18)" text-anchor="middle" style="fill:#000;font:bold 10px 'Segoe UI',sans-serif;">WB-301</text>
<text x="@wetCX" y="@(wetBotY + 30)" text-anchor="middle" style="fill:#333;font:400 9px 'Segoe UI',sans-serif;">Wet Bin</text>
</g>

@* ═══════ DRYING COLUMN DR-301 ═══════ *@
<g class="scada-equipment">
<rect x="@dryerX" y="@dryerY" width="@dryerW" height="@dryerH" rx="8" fill="url(#scada-tank-shell)" stroke="#555" stroke-width="1.5" />
<line x1="@dryerX" y1="@dryerY" x2="@(dryerX + dryerW)" y2="@dryerY" stroke="#555" stroke-width="2" />
<rect x="@(dryerX + 10)" y="@(dryerY + 10)" width="@(dryerW - 20)" height="30" rx="4" fill="@(HeatRunning ? "#ffdd67" : "#999")" stroke="#666" stroke-width="1" opacity="0.85" />
<text x="@dryerCX" y="@(dryerY + 30)" text-anchor="middle" style="fill:#333;font:bold 9px 'Segoe UI',sans-serif;">PLENUM</text>
<rect x="@(dryerX + 20)" y="@(dryerY + 60)" width="@(dryerW - 40)" height="@(dryerH * 0.55)" rx="4" fill="#e8e8e8" stroke="#aaa" stroke-width="1" />
@if (holdFillH > 0)
{
<rect x="@(dryerX + 20)" y="@(dryerY + 60 + dryerH * 0.55 - holdFillH)" width="@(dryerW - 40)" height="@holdFillH" fill="url(#scada-grain-fill)" clip-path="url(#dryer-clip)" opacity="0.85" />
}
<line x1="@(dryerX + 20 + (dryerW - 40) / 3)" y1="@(dryerY + 60)" x2="@(dryerX + 20 + (dryerW - 40) / 3)" y2="@(dryerY + 60 + dryerH * 0.55)" stroke="#aaa" stroke-width="1" />
<line x1="@(dryerX + 20 + 2 * (dryerW - 40) / 3)" y1="@(dryerY + 60)" x2="@(dryerX + 20 + 2 * (dryerW - 40) / 3)" y2="@(dryerY + 60 + dryerH * 0.55)" stroke="#aaa" stroke-width="1" />
<text x="@(dryerX + 20 + (dryerW - 40) / 6)" y="@(dryerY + 76)" text-anchor="middle" style="fill:#555;font:600 8px 'Segoe UI',sans-serif;">Z1</text>
<text x="@dryerCX" y="@(dryerY + 76)" text-anchor="middle" style="fill:#555;font:600 8px 'Segoe UI',sans-serif;">Z2</text>
<text x="@(dryerX + 20 + 5 * (dryerW - 40) / 6)" y="@(dryerY + 76)" text-anchor="middle" style="fill:#555;font:600 8px 'Segoe UI',sans-serif;">Z3</text>
<text x="@dryerCX" y="@(dryerBotY + 18)" text-anchor="middle" style="fill:#000;font:bold 10px 'Segoe UI',sans-serif;">DR-301</text>
<text x="@dryerCX" y="@(dryerBotY + 30)" text-anchor="middle" style="fill:#333;font:400 9px 'Segoe UI',sans-serif;">Drying Column</text>
</g>

@* ═══════ DRY BIN DB-301 ═══════ *@
<g class="scada-equipment">
<rect x="@dryX" y="@dryY" width="@tankW" height="@tankH" rx="@tankR" fill="url(#scada-tank-shell)" stroke="#555" stroke-width="1.5" />
@if (dryFillH > 0)
{
<rect x="@(dryX + 2)" y="@(dryBotY - dryFillH)" width="@(tankW - 4)" height="@dryFillH" fill="url(#scada-dry-fill)" clip-path="url(#dry-clip)" opacity="0.88" />
}
<line x1="@dryX" y1="@dryY" x2="@(dryX + tankW)" y2="@dryY" stroke="#555" stroke-width="2" />
<line x1="@(dryX + 6)" y1="@(dryY + 4)" x2="@(dryX + 6)" y2="@(dryBotY - 4)" stroke="rgba(255,255,255,0.5)" stroke-width="1.5" />
<line x1="@(dryX + tankW + 3)" y1="@dryY" x2="@(dryX + tankW + 8)" y2="@dryY" stroke="#333" stroke-width="1" />
<text x="@(dryX + tankW + 12)" y="@(dryY + 3)" style="fill:#000;font:600 7px 'Segoe UI',sans-serif;">HH</text>
<line x1="@(dryX + tankW + 3)" y1="@dryBotY" x2="@(dryX + tankW + 8)" y2="@dryBotY" stroke="#333" stroke-width="1" />
<text x="@(dryX + tankW + 12)" y="@(dryBotY + 3)" style="fill:#000;font:600 7px 'Segoe UI',sans-serif;">LL</text>
@if (DryBinFull)
{
<circle cx="@(dryX + tankW + 16)" cy="@(dryY + 8)" r="5" fill="#c62828" stroke="#fff" stroke-width="0.5">
<animate attributeName="opacity" values="1;0.3;1" dur="1s" repeatCount="indefinite" />
</circle>
}
<text x="@dryCX" y="@(dryBotY + 18)" text-anchor="middle" style="fill:#000;font:bold 10px 'Segoe UI',sans-serif;">DB-301</text>
<text x="@dryCX" y="@(dryBotY + 30)" text-anchor="middle" style="fill:#333;font:400 9px 'Segoe UI',sans-serif;">Dry Bin</text>
</g>

@* ═══════ FAN FN-301 ═══════ *@
<g class="scada-equipment">
<circle cx="@fanCX" cy="@fanCY" r="@fanR" fill="#e8e8e8" stroke="#555" stroke-width="1.5" />
<line x1="@(fanCX - 12)" y1="@(fanCY - 8)" x2="@(fanCX + 4)" y2="@(fanCY + 14)" stroke="#555" stroke-width="1.5" />
<line x1="@(fanCX + 12)" y1="@(fanCY - 8)" x2="@(fanCX - 4)" y2="@(fanCY + 14)" stroke="#555" stroke-width="1.5" />
<rect x="@fanMotorX" y="@fanMotorY" width="32" height="32" rx="3" fill="@(FanRunning ? "url(#scada-motor-run)" : "url(#scada-motor-off)")" stroke="#333" stroke-width="1" />
<text x="@(fanMotorX + 16)" y="@(fanMotorY + 20)" text-anchor="middle" style="fill:#fff;font:bold 10px 'Segoe UI',sans-serif;">M</text>
<line x1="@(fanCX + fanR)" y1="@fanCY" x2="@fanMotorX" y2="@(fanMotorY + 16)" stroke="#555" stroke-width="1.5" />
<text x="@fanCX" y="@(fanCY + fanR + 18)" text-anchor="middle" style="fill:#000;font:bold 10px 'Segoe UI',sans-serif;">FN-301</text>
<text x="@fanCX" y="@(fanCY + fanR + 30)" text-anchor="middle" style="fill:#333;font:400 9px 'Segoe UI',sans-serif;">Fan</text>
<text x="@(fanMotorX + 16)" y="@(fanMotorY - 4)" text-anchor="middle" style="fill:#000;font:bold 8px 'Segoe UI',sans-serif;">M-301</text>
</g>

@* ═══════ BURNER BR-301 ═══════ *@
<g class="scada-equipment">
<rect x="@burnerX" y="@burnerY" width="@burnerW" height="@burnerH" rx="4" fill="#e8e8e8" stroke="#555" stroke-width="1.5" />
<rect x="@(burnerX + 10)" y="@(burnerY + 8)" width="@(burnerW - 20)" height="@(burnerH - 16)" rx="3" fill="@(BurnerRunning ? "#ff8c00" : "#999")" stroke="#666" stroke-width="1" opacity="0.9" />
<text x="@(burnerX + burnerW / 2)" y="@(burnerY + burnerH / 2 + 4)" text-anchor="middle" style="fill:#fff;font:bold 10px 'Segoe UI',sans-serif;">@(BurnerRunning ? "🔥" : "OFF")</text>
<rect x="@burnerMotorX" y="@burnerMotorY" width="28" height="28" rx="3" fill="@(BurnerRunning ? "url(#scada-motor-run)" : "url(#scada-motor-off)")" stroke="#333" stroke-width="1" />
<text x="@(burnerMotorX + 14)" y="@(burnerMotorY + 18)" text-anchor="middle" style="fill:#fff;font:bold 9px 'Segoe UI',sans-serif;">M</text>
<text x="@(burnerX + burnerW / 2)" y="@(burnerY + burnerH + 18)" text-anchor="middle" style="fill:#000;font:bold 10px 'Segoe UI',sans-serif;">BR-301</text>
<text x="@(burnerX + burnerW / 2)" y="@(burnerY + burnerH + 30)" text-anchor="middle" style="fill:#333;font:400 9px 'Segoe UI',sans-serif;">Burner</text>
<text x="@(burnerMotorX + 14)" y="@(burnerMotorY - 4)" text-anchor="middle" style="fill:#000;font:bold 8px 'Segoe UI',sans-serif;">M-302</text>
</g>

@* ═══════ FEED DRIVE FD-301 ═══════ *@
<g class="scada-equipment">
<circle cx="@feedCX" cy="@feedCY" r="@feedR" fill="#e8e8e8" stroke="#555" stroke-width="1.5" />
<line x1="@(feedCX - 10)" y1="@(feedCY - 8)" x2="@(feedCX + 6)" y2="@(feedCY + 12)" stroke="#555" stroke-width="1.5" />
<line x1="@(feedCX + 10)" y1="@(feedCY - 8)" x2="@(feedCX - 6)" y2="@(feedCY + 12)" stroke="#555" stroke-width="1.5" />
<rect x="@feedMotorX" y="@feedMotorY" width="32" height="32" rx="3" fill="@(FeedRunning ? "url(#scada-motor-run)" : "url(#scada-motor-off)")" stroke="#333" stroke-width="1" />
<text x="@(feedMotorX + 16)" y="@(feedMotorY + 20)" text-anchor="middle" style="fill:#fff;font:bold 10px 'Segoe UI',sans-serif;">M</text>
<line x1="@(feedCX + feedR)" y1="@feedCY" x2="@feedMotorX" y2="@(feedMotorY + 16)" stroke="#555" stroke-width="1.5" />
<text x="@feedCX" y="@(feedCY + feedR + 18)" text-anchor="middle" style="fill:#000;font:bold 10px 'Segoe UI',sans-serif;">FD-301</text>
<text x="@feedCX" y="@(feedCY + feedR + 30)" text-anchor="middle" style="fill:#333;font:400 9px 'Segoe UI',sans-serif;">Feed Drive</text>
<text x="@(feedMotorX + 16)" y="@(feedMotorY - 4)" text-anchor="middle" style="fill:#000;font:bold 8px 'Segoe UI',sans-serif;">M-303</text>
</g>

@* ═══════ DISCHARGE CONVEYOR DC-301 ═══════ *@
<g class="scada-equipment">
<rect x="@convX" y="@convY" width="@convW" height="@convH" rx="4" fill="#e8e8e8" stroke="#555" stroke-width="1.5" />
<line x1="@(convX + 20)" y1="@(convY + convH / 2)" x2="@(convX + convW - 20)" y2="@(convY + convH / 2)" stroke="#888" stroke-width="2" stroke-dasharray="8,6" />
<circle cx="@(convX + 10)" cy="@(convY + convH / 2)" r="6" fill="#aaa" stroke="#555" stroke-width="1" />
<circle cx="@(convX + convW - 10)" cy="@(convY + convH / 2)" r="6" fill="#aaa" stroke="#555" stroke-width="1" />
<text x="@(convX + convW / 2)" y="@(convY + convH + 18)" text-anchor="middle" style="fill:#000;font:bold 10px 'Segoe UI',sans-serif;">DC-301</text>
<text x="@(convX + convW / 2)" y="@(convY + convH + 30)" text-anchor="middle" style="fill:#333;font:400 9px 'Segoe UI',sans-serif;">Discharge Conveyor</text>
</g>

@* ═══════ PIPING ═══════ *@
<g class="scada-piping">
@* Feed path: Wet Bin bottom → down → right → into Drying Column left *@
<line x1="@wetCX" y1="@wetBotY" x2="@wetCX" y2="@feedJunctionY" stroke="@materialColor" stroke-width="@pipeW" />
<line x1="@wetCX" y1="@feedJunctionY" x2="@dryerX" y2="@feedJunctionY" stroke="@materialColor" stroke-width="@pipeW" />

@* Hot air: Fan → Burner → up → Drying Column bottom *@
<line x1="@(fanCX + fanR)" y1="@fanCY" x2="@burnerX" y2="@(burnerY + burnerH / 2)" stroke="@airColor" stroke-width="@pipeW" />
<line x1="@(burnerX + burnerW)" y1="@(burnerY + burnerH / 2)" x2="@dryerCX" y2="@(burnerY + burnerH / 2)" stroke="@heatColor" stroke-width="@pipeW" />
<line x1="@dryerCX" y1="@(burnerY + burnerH / 2)" x2="@dryerCX" y2="@dryerBotY" stroke="@heatColor" stroke-width="@pipeW" />

@* Discharge: Drying Column right → right → Dry Bin top *@
<line x1="@(dryerX + dryerW)" y1="@dischJunctionY" x2="@dryCX" y2="@dischJunctionY" stroke="@dischargeColor" stroke-width="@pipeW" />
<line x1="@dryCX" y1="@dischJunctionY" x2="@dryCX" y2="@dryY" stroke="@dischargeColor" stroke-width="@pipeW" />

@* Exhaust: Drying Column top → up *@
<line x1="@(dryerCX + 40)" y1="@dryerY" x2="@(dryerCX + 40)" y2="@(processTop + 20)" stroke="#888" stroke-width="2" stroke-dasharray="6,4" />
<text x="@(dryerCX + 42)" y="@(processTop + 16)" style="fill:#555;font:600 8px 'Segoe UI',sans-serif;">EXHAUST</text>

@* Conveyor feed: Drying Column bottom → down → Conveyor *@
<line x1="@(dryerCX - 40)" y1="@dryerBotY" x2="@(dryerCX - 40)" y2="@(convY + convH / 2)" stroke="@dischargeColor" stroke-width="@pipeW" />
<line x1="@(dryerCX - 40)" y1="@(convY + convH / 2)" x2="@convX" y2="@(convY + convH / 2)" stroke="@dischargeColor" stroke-width="@pipeW" />

@* Feed path arrows *@
@if (FeedPathActive)
{
<polygon points="@(wetCX - 4),@(wetBotY + 10) @(wetCX + 4),@(wetBotY + 10) @(wetCX),@(wetBotY + 18)" fill="@materialColor" />
<polygon points="@(dryerX - 16),@(feedJunctionY - 4) @(dryerX - 16),@(feedJunctionY + 4) @(dryerX - 8),@feedJunctionY" fill="@materialColor" />
}
@if (HeatRunning)
{
<polygon points="@(burnerX - 14),@(burnerY + burnerH / 2 - 4) @(burnerX - 14),@(burnerY + burnerH / 2 + 4) @(burnerX - 6),@(burnerY + burnerH / 2)" fill="@airColor" />
<polygon points="@(dryerCX - 4),@(dryerBotY - 4) @(dryerCX + 4),@(dryerBotY - 4) @(dryerCX),@(dryerBotY - 12)" fill="@heatColor" />
}
@if (DischargeActive)
{
<polygon points="@(dryCX - 4),@(dischJunctionY - 20) @(dryCX + 4),@(dischJunctionY - 20) @(dryCX),@(dischJunctionY - 28)" fill="@dischargeColor" />
}
</g>

