@namespace SkyNet.Simulator.Dashboard.Components

@{
	var top = CenterY - 18.0;
	var leftFlangeX = 40.0;
	var rightFlangeX = Width - 58.0;
}

<g class="schematic-glyph schematic-pipe-module">
	<line x1="8" y1="@CenterY" x2="28" y2="@CenterY" stroke="@VisualStyle.DetailStroke" stroke-width="4" stroke-linecap="round" />
	<line x1="@(Width - 28)" y1="@CenterY" x2="@(Width - 8)" y2="@CenterY" stroke="@VisualStyle.DetailStroke" stroke-width="4" stroke-linecap="round" />
	<rect x="32" y="@(top - 2)" width="@(Width - 64)" height="40" rx="20" ry="20" fill="var(--node-shell-shadow)" opacity="0.16" />
	<rect x="28" y="@top" width="@(Width - 56)" height="36" rx="18" ry="18" fill="@VisualStyle.ShellFill" stroke="@VisualStyle.ShellStroke" stroke-width="2.4" />
	<rect x="52" y="@(top + 8)" width="@(Width - 104)" height="20" rx="10" ry="10" fill="@VisualStyle.CoreFill" stroke="@VisualStyle.ShellStroke" stroke-width="1.2" opacity="0.92" />
	<rect x="@leftFlangeX" y="@(top - 4)" width="10" height="44" rx="5" ry="5" fill="@VisualStyle.BaseFill" stroke="@VisualStyle.ShellStroke" stroke-width="1.4" />
	<rect x="@rightFlangeX" y="@(top - 4)" width="10" height="44" rx="5" ry="5" fill="@VisualStyle.BaseFill" stroke="@VisualStyle.ShellStroke" stroke-width="1.4" />
	<circle cx="@(Width / 2.0)" cy="@(top + 6)" r="4.5" fill="@VisualStyle.PortCapFill" stroke="@VisualStyle.ShellStroke" stroke-width="1.6" />
	<line x1="@(Width / 2.0)" y1="@(top - 8)" x2="@(Width / 2.0)" y2="@(top + 2)" stroke="@VisualStyle.DetailStroke" stroke-width="2" stroke-linecap="round" />
	<line x1="74" y1="@CenterY" x2="96" y2="@CenterY" stroke="@VisualStyle.DetailStroke" stroke-width="1.8" stroke-linecap="round" />
	<line x1="108" y1="@CenterY" x2="130" y2="@CenterY" stroke="@VisualStyle.DetailStroke" stroke-width="1.8" stroke-linecap="round" />
	<line x1="142" y1="@CenterY" x2="164" y2="@CenterY" stroke="@VisualStyle.DetailStroke" stroke-width="1.8" stroke-linecap="round" />
</g>

@code {
	[CascadingParameter] public SchematicVisualStyle VisualStyle { get; set; } = SchematicVisualStyle.Default;
	[Parameter] public double Width { get; set; } = 220;
	[Parameter] public double CenterY { get; set; } = 104;
}