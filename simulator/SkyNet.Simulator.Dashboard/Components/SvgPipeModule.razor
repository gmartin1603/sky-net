@namespace SkyNet.Simulator.Dashboard.Components

@{
	var top = CenterY - 14.0;
	var leftFlangeX = 42.0;
	var rightFlangeX = Width - 56.0;
	var centerX = Width / 2.0;
	var gaugeArcPath = $"M{F(centerX - 8)} {F(top - 19)} A8 8 0 0 1 {F(centerX + 8)} {F(top - 19)}";
}

<g class="schematic-glyph schematic-pipe-module">
	<line x1="8" y1="@CenterY" x2="28" y2="@CenterY" stroke="@VisualStyle.DetailStroke" stroke-width="4" stroke-linecap="round" />
	<line x1="@(Width - 28)" y1="@CenterY" x2="@(Width - 8)" y2="@CenterY" stroke="@VisualStyle.DetailStroke" stroke-width="4" stroke-linecap="round" />
	<rect x="32" y="@(top - 2)" width="@(Width - 64)" height="32" rx="16" ry="16" fill="var(--node-shell-shadow)" opacity="0.16" />
	<rect x="28" y="@top" width="@(Width - 56)" height="28" rx="14" ry="14" fill="@VisualStyle.ShellFill" stroke="@VisualStyle.ShellStroke" stroke-width="2.2" />
	<rect x="52" y="@(top + 6)" width="@(Width - 104)" height="16" rx="8" ry="8" fill="@VisualStyle.CoreFill" stroke="@VisualStyle.ShellStroke" stroke-width="1.1" opacity="0.92" />
	<rect x="@leftFlangeX" y="@(top - 4)" width="10" height="44" rx="5" ry="5" fill="@VisualStyle.BaseFill" stroke="@VisualStyle.ShellStroke" stroke-width="1.4" />
	<rect x="@rightFlangeX" y="@(top - 4)" width="10" height="44" rx="5" ry="5" fill="@VisualStyle.BaseFill" stroke="@VisualStyle.ShellStroke" stroke-width="1.4" />
	<rect x="@(centerX - 16)" y="@(top - 28)" width="32" height="18" rx="4" ry="4" fill="#f3ead7" stroke="#847157" stroke-width="1.2" />
	<line x1="@centerX" y1="@(top - 10)" x2="@centerX" y2="@(top + 1)" stroke="@VisualStyle.DetailStroke" stroke-width="2" stroke-linecap="round" />
	<path d="@gaugeArcPath" fill="none" stroke="#6b6357" stroke-width="1.2" />
	<line x1="@centerX" y1="@(top - 19)" x2="@(centerX + 5)" y2="@(top - 23)" stroke="#d74628" stroke-width="1.2" stroke-linecap="round" />
	<line x1="74" y1="@CenterY" x2="96" y2="@CenterY" stroke="@VisualStyle.DetailStroke" stroke-width="1.8" stroke-linecap="round" />
	<line x1="108" y1="@CenterY" x2="130" y2="@CenterY" stroke="@VisualStyle.DetailStroke" stroke-width="1.8" stroke-linecap="round" />
	<line x1="142" y1="@CenterY" x2="164" y2="@CenterY" stroke="@VisualStyle.DetailStroke" stroke-width="1.8" stroke-linecap="round" />
	<circle cx="@(rightFlangeX + 22)" cy="@(CenterY + 14)" r="7" fill="#d74628" stroke="#6f2217" stroke-width="1.3" />
	<line x1="@(rightFlangeX + 15)" y1="@(CenterY + 14)" x2="@(rightFlangeX + 29)" y2="@(CenterY + 14)" stroke="#f7cabc" stroke-width="1.7" stroke-linecap="round" />
	<line x1="@(rightFlangeX + 22)" y1="@(CenterY + 7)" x2="@(rightFlangeX + 22)" y2="@(CenterY + 21)" stroke="#f7cabc" stroke-width="1.7" stroke-linecap="round" />
</g>

@code {
	private static string F(double value) => value.ToString("0.###", System.Globalization.CultureInfo.InvariantCulture);

	[CascadingParameter] public SchematicVisualStyle VisualStyle { get; set; } = SchematicVisualStyle.Default;
	[Parameter] public double Width { get; set; } = 220;
	[Parameter] public double CenterY { get; set; } = 104;
}
