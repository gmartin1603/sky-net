<OpsModal Visible="@_showTrendModal" Title="@(_activeTrendMeta?.Tag ?? "Signal Trend")" Subtitle="@(_activeTrendMeta?.Label)" OnClose="CloseTrendModalAsync">
	@if (_activeTrendMeta is not null)
	{
		<div style="display:flex;gap:1.5rem;align-items:baseline;margin-bottom:0.5rem;">
			<div><span style="opacity:0.7;font-size:0.85rem;">Current value</span><br/><strong>@FormatTrendValue(_activeTrendMeta)</strong></div>
			<div><span style="opacity:0.7;font-size:0.85rem;">Signal</span><br/><strong>@_activeTrendMeta.Label</strong></div>
		</div>
		<LineChart Title="@_activeTrendMeta.Tag" SubTitle="@_activeTrendMeta.Unit" Stroke="var(--chart-series-2)" Points="@GetTrendPoints(_activeTrendMeta.Key)" YFormat="@_activeTrendMeta.Format" Width="880" Height="240" />
	}
</OpsModal>

<OpsModal Visible="@_showSetpointModal" Title="SP-301 — Pressure Setpoint" Subtitle="Adjust the blowline pressure command" OnClose="CloseSetpointModalAsync">
	<div style="display:flex;gap:1.5rem;align-items:baseline;margin-bottom:0.75rem;">
		<div><span style="opacity:0.7;font-size:0.85rem;">Current setpoint</span><br/><strong>@BlowlinePressureCmdPsi.ToString("0.0", System.Globalization.CultureInfo.InvariantCulture) psi</strong></div>
		<div><span style="opacity:0.7;font-size:0.85rem;">Actual line pressure</span><br/><strong>@BlowlinePressurePsi.ToString("0.00", System.Globalization.CultureInfo.InvariantCulture) psi</strong></div>
	</div>
	<div style="display:flex;gap:0.75rem;align-items:end;flex-wrap:wrap;">
		<div>
			<label style="display:block;font-size:0.8rem;font-weight:600;margin-bottom:0.25rem;">Target PSI</label>
			<input type="number" min="0" max="25" step="0.5" style="width:6rem;padding:0.4rem 0.5rem;border:1px solid var(--app-panel-stroke);border-radius:6px;background:var(--app-surface-elevated);color:var(--app-fg);font-size:1rem;" value="@_setpointDraft" @onchange="OnSetpointDraftChanged" />
		</div>
		<button type="button" style="padding:0.5rem 1rem;border:none;border-radius:6px;background:var(--app-accent);color:#fff;font-weight:700;cursor:pointer;" @onclick="ApplySetpointAsync">Apply</button>
