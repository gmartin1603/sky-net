<rect x="@(sidebarX + 16)" y="@(pageY - 8)" width="@(sidebarW - 28)" height="14" fill="@bgColor" />
<g><text x="@(sidebarX + 24)" y="@pageY" style="fill:#000;font:@fontWeight 9px 'Segoe UI',sans-serif;">@pageName</text></g>
