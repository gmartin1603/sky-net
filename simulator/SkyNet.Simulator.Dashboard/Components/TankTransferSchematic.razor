		{
			<button type="button" style="padding:0.35rem 0.75rem;border:1px solid var(--app-panel-stroke);border-radius:6px;background:var(--app-surface-elevated);color:var(--app-fg);font-weight:600;cursor:pointer;" @onclick="() => ApplySetpointPresetAsync(preset)">@preset.ToString("0", System.Globalization.CultureInfo.InvariantCulture) psi</button>
		}
	</div>
</OpsModal>

@code {
	[Parameter] public string SimId { get; set; } = string.Empty;
	[Parameter] public TelemetrySnapshot? Snapshot { get; set; }
	[Parameter] public TankTransferSchematicLayout? Layout { get; set; }

	private const string ParamBlowerEnable = "BlowerEnable";
	private const string ParamAirlockEnable = "AirlockEnable";
	private const string ParamBlowlinePressureCommandPsi = "BlowlinePressureCommandPsi";

	// ── Setpoint modal state ──
	private bool _showSetpointModal;
	private string _setpointDraft = string.Empty;
	private static readonly double[] _pressurePresets = [6, 10, 14, 18];

	// ── Trend modal state ──
	private bool _showTrendModal;
	private TrendMeta? _activeTrendMeta;
	private double _lastTrendTimeSeconds = double.NaN;
	private readonly Dictionary<string, List<LineChart.Point>> _trendHistory = new(StringComparer.OrdinalIgnoreCase);
	private const int MaxTrendPoints = 300;

	private static class TrendKey
	{
		public const string SourceTankWeightLb = nameof(SourceTankWeightLb);
		public const string DestinationTankWeightLb = nameof(DestinationTankWeightLb);
		public const string BlowlinePressurePsi = nameof(BlowlinePressurePsi);
		public const string TransferRateLbPerSec = nameof(TransferRateLbPerSec);
		public const string BlowerMotorPercentFla = nameof(BlowerMotorPercentFla);
		public const string AirlockSpeedHz = nameof(AirlockSpeedHz);
	}

	private sealed record TrendMeta(string Key, string Tag, string Label, string Unit, string Format, Func<TankTransferSchematic, double> ReadValue);

	private static readonly IReadOnlyDictionary<string, TrendMeta> TrendMetrics = new Dictionary<string, TrendMeta>(StringComparer.OrdinalIgnoreCase)
	{
		[TrendKey.SourceTankWeightLb] = new(TrendKey.SourceTankWeightLb, "WT-301", "Source Tank Weight", "lb", "0", s => s.SourceTankWeight),
		[TrendKey.DestinationTankWeightLb] = new(TrendKey.DestinationTankWeightLb, "WT-302", "Destination Tank Weight", "lb", "0", s => s.DestinationTankWeight),
		[TrendKey.BlowlinePressurePsi] = new(TrendKey.BlowlinePressurePsi, "PT-301", "Blowline Pressure", "psi", "0.00", s => s.BlowlinePressurePsi),
		[TrendKey.TransferRateLbPerSec] = new(TrendKey.TransferRateLbPerSec, "FT-301", "Transfer Rate", "lb/s", "0.00", s => s.TransferRateLbPerSec),
		[TrendKey.BlowerMotorPercentFla] = new(TrendKey.BlowerMotorPercentFla, "M-301", "Blower Motor Load", "% FLA", "0.0", s => s.BlowerMotorPercentFla),
		[TrendKey.AirlockSpeedHz] = new(TrendKey.AirlockSpeedHz, "SI-301", "Airlock Speed", "Hz", "0.0", s => s.AirlockSpeedHz),
	};
private async Task ToggleAsync(string parameterName)
{
if (Snapshot is null || string.IsNullOrWhiteSpace(SimId))
{
return;
}

if (!Snapshot.Parameters.TryGetValue(parameterName, out var current))
{
current = 0;
}

var next = current >= 0.5 ? 0.0 : 1.0;
await Api.SetParameterAsync(SimId, parameterName, next);
}

private double GetSignal(string name) => Snapshot?.Signals.TryGetValue(name, out var value) == true ? value : double.NaN;
private double GetParameter(string name) => Snapshot?.Parameters.TryGetValue(name, out var value) == true ? value : double.NaN;

private bool BlowerRunning => GetSignal("BlowerRunning") >= 0.5;
private bool AirlockRunning => GetSignal("AirlockRunning") >= 0.5;
private bool PressureControlEnabled => GetParameter("PressureControlEnable") >= 0.5;
private bool TransferPermitted => BlowerRunning;
private string BlowerStatus => BlowerRunning ? "Running" : "Stopped";
private string AirlockStatus => AirlockRunning ? "Running" : "Stopped";
private string ControlModeLabel => PressureControlEnabled ? "Auto Hold" : "Manual Rate";
private string LoopStatusLabel => TransferPermitted ? "Enabled" : "Waiting";

private double SourceTankWeight => GetSignal("SourceTankWeightLb");
private double DestinationTankWeight => GetSignal("DestinationTankWeightLb");
private double TransferRateLbPerSec => GetSignal("TransferRateLbPerSec");
private double BlowlinePressurePsi => GetSignal("BlowlinePressurePsi");
private double BlowlinePressureCmdPsi => GetSignal("BlowlinePressureCommandPsi");
private double AirlockSpeedHz => GetSignal("AirlockSpeedHz");
private double BlowerMotorPercentFla => GetSignal("BlowerMotorPercentFla");
private double SourceTankCapacity => GetParameter("SourceTankCapacityLb");

private bool IsStarved => GetSignal("IsStarved") >= 0.5;
private bool IsFull => GetSignal("IsFull") >= 0.5;
private bool ActiveFault => IsStarved || IsFull;
private string FaultLabel => IsFull ? "Destination full" : IsStarved ? "Feed starved" : "None";

	protected override void OnParametersSet()
	{
		CaptureTrendSnapshot();
	}

	// ── Trend helpers ──
	private void CaptureTrendSnapshot()
	{
		if (Snapshot is null) return;
		var t = Snapshot.TimeSeconds;
		if (!double.IsNaN(_lastTrendTimeSeconds) && Math.Abs(_lastTrendTimeSeconds - t) < 1e-9) return;
		_lastTrendTimeSeconds = t;
		foreach (var m in TrendMetrics.Values)
		{
			if (!_trendHistory.TryGetValue(m.Key, out var pts))
			{
				pts = new List<LineChart.Point>(MaxTrendPoints);
				_trendHistory[m.Key] = pts;
			}
			pts.Add(new LineChart.Point(t, m.ReadValue(this)));
			if (pts.Count > MaxTrendPoints) pts.RemoveRange(0, pts.Count - MaxTrendPoints);
		}
	}

	private void OpenTrend(string trendKey)
	{
		if (!TrendMetrics.TryGetValue(trendKey, out var meta)) return;
		_activeTrendMeta = meta;
		_showTrendModal = true;
	}

	private Task CloseTrendModalAsync()
	{
		_showTrendModal = false;
		return Task.CompletedTask;
	}

	private LineChart.Point[] GetTrendPoints(string key) =>
		_trendHistory.TryGetValue(key, out var pts) ? pts.ToArray() : Array.Empty<LineChart.Point>();

	private string FormatTrendValue(TrendMeta meta)
	{
		var v = meta.ReadValue(this);
		return $"{v.ToString(meta.Format, System.Globalization.CultureInfo.InvariantCulture)} {meta.Unit}";
	}

	// ── Setpoint helpers ──
	private void OpenSetpointModal()
	{
		_setpointDraft = BlowlinePressureCmdPsi.ToString("0.0", System.Globalization.CultureInfo.InvariantCulture);
		_showSetpointModal = true;
	}

	private Task CloseSetpointModalAsync()
	{
		_showSetpointModal = false;
		return Task.CompletedTask;
	}

	private void OnSetpointDraftChanged(ChangeEventArgs e) => _setpointDraft = e.Value?.ToString() ?? string.Empty;

	private async Task ApplySetpointAsync()
	{
		if (string.IsNullOrWhiteSpace(SimId)) return;
		if (double.TryParse(_setpointDraft, System.Globalization.NumberStyles.Float, System.Globalization.CultureInfo.InvariantCulture, out var v))
		{
			var clamped = Math.Clamp(v, 0.0, 25.0);
			await Api.SetParameterAsync(SimId, ParamBlowlinePressureCommandPsi, clamped);
			_setpointDraft = clamped.ToString("0.0", System.Globalization.CultureInfo.InvariantCulture);
		}
	}

	private async Task ApplySetpointPresetAsync(double preset)
	{
		if (string.IsNullOrWhiteSpace(SimId)) return;
		var clamped = Math.Clamp(preset, 0.0, 25.0);
		await Api.SetParameterAsync(SimId, ParamBlowlinePressureCommandPsi, clamped);
		_setpointDraft = clamped.ToString("0.0", System.Globalization.CultureInfo.InvariantCulture);
	}
}
