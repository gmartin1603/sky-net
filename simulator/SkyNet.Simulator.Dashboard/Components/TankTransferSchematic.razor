<text x="@(sidebarX + 12)" y="@(pageY + 10)" style="fill:#000;font:bold 9px 'Segoe UI',sans-serif;">⊞ Alarms</text>
<text x="@(sidebarX + 12)" y="@(pageY + 28)" style="fill:#000;font:bold 9px 'Segoe UI',sans-serif;">⊞ Trends</text>
<text x="@(sidebarX + 12)" y="@(pageY + 46)" style="fill:#000;font:bold 9px 'Segoe UI',sans-serif;">⊞ Tools</text>

@* ═══════ STATUS BAR ═══════ *@
<rect x="0" y="@(scadaH - statusBarH)" width="@scadaW" height="@statusBarH" fill="#e0e0e0" stroke="#aaa" stroke-width="0.5" />
<text x="@(scadaW - 12)" y="@(scadaH - 8)" text-anchor="end" style="fill:#333;font:600 9px 'Segoe UI',sans-serif;">Sim @Snapshot.TimeSeconds.ToString("000.0", System.Globalization.CultureInfo.InvariantCulture)s — @DateTime.Now.ToString("ddd MMM dd yyyy — HH:mm:ss")</text>
<text x="12" y="@(scadaH - 8)" style="fill:#333;font:600 9px 'Segoe UI',sans-serif;">@ControlModeLabel.ToUpperInvariant() | Transfer: @TransferRateLbPerSec.ToString("0.0", System.Globalization.CultureInfo.InvariantCulture) lb/s | Line: @BlowlinePressurePsi.ToString("0.0", System.Globalization.CultureInfo.InvariantCulture) psi</text>

<rect x="@(sidebarX + 8)" y="@(scadaH - statusBarH - 30)" width="@(sidebarW - 16)" height="14" rx="2" fill="#ddd" stroke="#bbb" stroke-width="0.5" />
<rect x="@(sidebarX + 10)" y="@(scadaH - statusBarH - 28)" width="60" height="10" rx="2" fill="#999" />
</svg>
</div>

