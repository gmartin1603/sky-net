@using SkyNet.Simulator.Contracts
@using SkyNet.Simulator.Dashboard.Services

@inject SimApiClient Api

@if (Snapshot is null)
{
<div class="tank-hmi-shell tank-hmi-shell-empty">
<div class="tank-hmi-empty">Waiting for telemetry...</div>
</div>
}
else
{
var schematicLayout = Layout ?? TankTransferSchematicLayout.Default;
var destinationCapacity = GetParameter("DestinationTankCapacityLb");
var destinationFillRatio = destinationCapacity > 0 ? Math.Clamp(DestinationTankWeight / destinationCapacity, 0.0, 1.0) : (double?)null;
var sourceFillRatio = SourceTankCapacity > 0 ? Math.Clamp(SourceTankWeight / SourceTankCapacity, 0.0, 1.0) : (double?)null;
var sourceAlert = IsStarved;
var destinationAlert = IsFull;
var pipeColor = TransferPermitted ? "#0070c0" : "#606060";
var pipeWidth = TransferPermitted ? 3.0 : 2.0;
var canvasWidth = schematicLayout.CanvasWidth.ToString("0.#", System.Globalization.CultureInfo.InvariantCulture);
var canvasHeight = schematicLayout.CanvasHeight.ToString("0.#", System.Globalization.CultureInfo.InvariantCulture);

var scadaW = schematicLayout.CanvasWidth;
var scadaH = schematicLayout.CanvasHeight;
var alarmBannerH = 64.0;
var tabBarH = 28.0;
var titleBarH = 34.0;
var statusBarH = 24.0;
var sidebarW = 200.0;
var processTop = alarmBannerH + tabBarH + titleBarH;
var processH = scadaH - processTop - statusBarH;
var processW = scadaW - sidebarW;

var tankW = 80.0;
var tankH = 120.0;
var tankShellR = 6.0;

var srcTankX = 140.0;
var srcTankY = processTop + 60.0;
var srcTankCX = srcTankX + tankW / 2.0;
var srcTankBotY = srcTankY + tankH;

var dstTankX = 620.0;
var dstTankY = processTop + 60.0;
var dstTankCX = dstTankX + tankW / 2.0;
var dstTankBotY = dstTankY + tankH;

var blowerX = 310.0;
var blowerY = processTop + processH - 120.0;
var blowerR = 22.0;
var blowerCX = blowerX;
var blowerCY = blowerY;

var airlockX = 460.0;
var airlockY = blowerY;
var airlockW = 50.0;
var airlockH = 30.0;

var blowerMotorX = blowerX + 38.0;
var blowerMotorY = blowerY - 16.0;
var airlockMotorX = airlockX + airlockW + 8.0;
var airlockMotorY = airlockY - 12.0;

var pipeJunctionY = blowerY;
var airlockCX = airlockX + airlockW / 2.0;
var materialRouteY = airlockY - airlockH / 2.0 - 20.0;

var fmX = 560.0;
var fmY = blowerY - 6.0;

var srcFillH = sourceFillRatio.HasValue ? Math.Max(0.0, tankH * sourceFillRatio.Value) : 0.0;
var dstFillH = destinationFillRatio.HasValue ? Math.Max(0.0, tankH * destinationFillRatio.Value) : 0.0;

var selPanelX = processW - 180.0;
var selPanelY = processTop + 10.0;

var readout1X = 255.0;
var readout1Y = processTop + 100.0;
var readout2X = fmX - 10.0;
var readout2Y = blowerY - 50.0;

var sidebarX = processW;

<section class="tank-hmi-shell scada-industrial">
<div class="scada-canvas-wrap">
<svg viewBox="@($"0 0 {canvasWidth} {canvasHeight}")" class="scada-svg" xmlns="http://www.w3.org/2000/svg">
<defs>
<linearGradient id="scada-tank-shell" x1="0" y1="0" x2="1" y2="0">
<stop offset="0%" stop-color="#b0b0b0" />
<stop offset="30%" stop-color="#d8d8d8" />
<stop offset="70%" stop-color="#e8e8e8" />
<stop offset="100%" stop-color="#c0c0c0" />
</linearGradient>
<linearGradient id="scada-water-fill" x1="0" y1="0" x2="0" y2="1">
<stop offset="0%" stop-color="#5ba3d9" />
<stop offset="100%" stop-color="#2878b5" />
</linearGradient>
<linearGradient id="scada-motor-running" x1="0" y1="0" x2="0" y2="1">
<stop offset="0%" stop-color="#4caf50" />
<stop offset="100%" stop-color="#2e7d32" />
</linearGradient>
<linearGradient id="scada-motor-stopped" x1="0" y1="0" x2="0" y2="1">
<stop offset="0%" stop-color="#909090" />
<stop offset="100%" stop-color="#686868" />
</linearGradient>
<linearGradient id="scada-alarm-bar" x1="0" y1="0" x2="0" y2="1">
<stop offset="0%" stop-color="#1a1a2e" />
<stop offset="100%" stop-color="#0d0d1a" />
</linearGradient>
<clipPath id="src-tank-clip">
<rect x="@(srcTankX + 2)" y="@(srcTankY + 2)" width="@(tankW - 4)" height="@(tankH - 4)" rx="@(tankShellR - 1)" ry="@(tankShellR - 1)" />
</clipPath>
<clipPath id="dst-tank-clip">
<rect x="@(dstTankX + 2)" y="@(dstTankY + 2)" width="@(tankW - 4)" height="@(tankH - 4)" rx="@(tankShellR - 1)" ry="@(tankShellR - 1)" />
</clipPath>
</defs>

@* ═══════ ALARM BANNER ═══════ *@
<rect x="0" y="0" width="@scadaW" height="@alarmBannerH" fill="url(#scada-alarm-bar)" />
<line x1="0" y1="@alarmBannerH" x2="@scadaW" y2="@alarmBannerH" stroke="#444" stroke-width="1" />
<g transform="translate(12, 8)">
<rect x="0" y="0" width="24" height="18" rx="3" fill="#333" stroke="#555" stroke-width="0.8" />
<text x="12" y="13" text-anchor="middle" style="fill:#ffc107;font:bold 10px monospace;">⚠</text>
<text x="30" y="13" style="fill:#aaa;font:600 9px 'Segoe UI',sans-serif;">@(ActiveFault ? "1" : "0")</text>
</g>
<g transform="translate(70, 8)">
<rect x="0" y="0" width="18" height="18" rx="3" fill="@(ActiveFault ? "#c62828" : "#333")" stroke="#555" stroke-width="0.8" />
<text x="9" y="13" text-anchor="middle" style="fill:#fff;font:bold 8px monospace;">!</text>
</g>
<text x="100" y="18" style="fill:#999;font:600 8px 'Consolas',monospace;letter-spacing:0.02em;">DATE/TIME</text>
<text x="260" y="18" style="fill:#999;font:600 8px 'Consolas',monospace;letter-spacing:0.02em;">TAG</text>
<text x="460" y="18" style="fill:#999;font:600 8px 'Consolas',monospace;letter-spacing:0.02em;">DESCRIPTION</text>
<text x="700" y="18" style="fill:#999;font:600 8px 'Consolas',monospace;letter-spacing:0.02em;">PRIORITY</text>
<line x1="96" y1="22" x2="@(scadaW - 10)" y2="22" stroke="#444" stroke-width="0.5" />
@if (ActiveFault)
{
var alarmColor = IsFull ? "#ff6659" : "#ffab40";
<rect x="96" y="26" width="@(scadaW - 106)" height="14" fill="rgba(198,40,40,0.15)" />
<g><text x="100" y="36" style="fill:@alarmColor;font:600 9px 'Consolas',monospace;">@DateTime.Now.ToString("dd/M/yyyy  hh:mm:ss tt")</text></g>
<g><text x="260" y="36" style="fill:@alarmColor;font:600 9px 'Consolas',monospace;">@(IsFull ? "TK302_HH_Alm" : "TK301_LL_Alm")</text></g>
<g><text x="460" y="36" style="fill:@alarmColor;font:600 9px 'Consolas',monospace;">@(IsFull ? "Tank 302 High High Level" : "Tank 301 Low Low Level")</text></g>
<g><text x="700" y="36" style="fill:@alarmColor;font:bold 9px 'Consolas',monospace;">@(IsFull ? "HH" : "LL")</text></g>
}
else
{
<g><text x="100" y="36" style="fill:#666;font:600 9px 'Consolas',monospace;">(no active alarms)</text></g>
}

@* ═══════ TAB BAR ═══════ *@
<rect x="0" y="@alarmBannerH" width="@scadaW" height="@tabBarH" fill="#008000" />
<line x1="0" y1="@(alarmBannerH + tabBarH)" x2="@scadaW" y2="@(alarmBannerH + tabBarH)" stroke="#004d00" stroke-width="1" />
@{
var tabs = new[] { ("TankTransfer_C3", true), ("BlowlinePressure", false), ("EquipmentStatus", false), ("MotorDrives", false), ("AlarmHistory", false) };
var tabX = 24.0;
}
@foreach (var (tabName, isActive) in tabs)
{
var tw = tabName.Length * 7.6 + 24;
var tabFill = isActive ? "#c0c0c0" : "#009900";
var tabStroke = isActive ? "#888" : "#006600";
var tabTextColor = isActive ? "#000" : "#fff";
<rect x="@tabX" y="@(alarmBannerH + 4)" width="@tw" height="@(tabBarH - 6)" rx="3" ry="0" fill="@tabFill" stroke="@tabStroke" stroke-width="0.8" />
<g><text x="@(tabX + tw / 2)" y="@(alarmBannerH + 18)" text-anchor="middle" style="fill:@tabTextColor;font:600 9px 'Segoe UI',Tahoma,sans-serif;">@tabName</text></g>
tabX += tw + 4;
}
<text x="@(scadaW - 60)" y="@(alarmBannerH + 19)" style="fill:#fff;font:bold 13px sans-serif;">‹‹</text>
<text x="@(scadaW - 40)" y="@(alarmBannerH + 19)" style="fill:#fff;font:bold 13px sans-serif;">››</text>

@* ═══════ TITLE BAR ═══════ *@
<rect x="0" y="@(alarmBannerH + tabBarH)" width="@processW" height="@titleBarH" fill="#e8e8e8" stroke="#aaa" stroke-width="0.5" />
<rect x="@((processW - 420) / 2)" y="@(alarmBannerH + tabBarH + 4)" width="420" height="@(titleBarH - 8)" rx="2" fill="#fff" stroke="#000" stroke-width="1.5" />
<text x="@(processW / 2)" y="@(alarmBannerH + tabBarH + 24)" text-anchor="middle" style="fill:#000;font:bold 15px 'Segoe UI',Tahoma,sans-serif;letter-spacing:0.06em;">TANK TRANSFER STATION C3</text>

@* ═══════ PROCESS AREA ═══════ *@
<rect x="0" y="@processTop" width="@processW" height="@processH" fill="#c0c0c0" />

@* ═══════ FEED LABELS ═══════ *@
<g>
@{
var feedLabelY = processTop + 70.0;
var feedLabels = new[] { ("Product A", "TK-301"), ("Source Feed", "Feed Line") };
}
@foreach (var (label, tag) in feedLabels)
{
<line x1="4" y1="@feedLabelY" x2="@(srcTankX - 10)" y2="@feedLabelY" stroke="#000" stroke-width="1" />
<rect x="4" y="@(feedLabelY - 10)" width="70" height="12" fill="#c0c0c0" />
<g><text x="6" y="@(feedLabelY - 1)" style="fill:#000;font:600 8px 'Segoe UI',sans-serif;">@label</text></g>
<g><text x="6" y="@(feedLabelY + 9)" style="fill:#000;font:400 7px 'Segoe UI',sans-serif;">@tag</text></g>
feedLabelY += 30.0;
}
</g>

@* ═══════ SELECTOR SWITCH ═══════ *@
<rect x="@selPanelX" y="@selPanelY" width="170" height="70" rx="3" fill="#e0e0e0" stroke="#888" stroke-width="1" />
<text x="@(selPanelX + 8)" y="@(selPanelY + 14)" style="fill:#000;font:bold 9px 'Segoe UI',sans-serif;">Selector Switch</text>
<line x1="@selPanelX" y1="@(selPanelY + 20)" x2="@(selPanelX + 170)" y2="@(selPanelY + 20)" stroke="#aaa" stroke-width="0.5" />
<text x="@(selPanelX + 8)" y="@(selPanelY + 34)" style="fill:#000;font:600 8px 'Segoe UI',sans-serif;">Transfer C3</text>
<text x="@(selPanelX + 90)" y="@(selPanelY + 34)" style="fill:#000;font:bold 8px 'Segoe UI',sans-serif;">Auto</text>
<text x="@(selPanelX + 122)" y="@(selPanelY + 34)" style="fill:#000;font:bold 8px 'Segoe UI',sans-serif;">Manual</text>
<rect x="@(selPanelX + 88)" y="@(selPanelY + 40)" width="34" height="20" rx="2" fill="@(TransferPermitted ? "#4caf50" : "#808080")" stroke="#333" stroke-width="0.8" />
<text x="@(selPanelX + 105)" y="@(selPanelY + 54)" text-anchor="middle" style="fill:#fff;font:bold 9px 'Segoe UI',sans-serif;">ON</text>
<rect x="@(selPanelX + 128)" y="@(selPanelY + 40)" width="34" height="20" rx="2" fill="@(!TransferPermitted ? "#c62828" : "#808080")" stroke="#333" stroke-width="0.8" />
<text x="@(selPanelX + 145)" y="@(selPanelY + 54)" text-anchor="middle" style="fill:#fff;font:bold 9px 'Segoe UI',sans-serif;">OFF</text>

@* ═══════ SOURCE TANK TK-301 ═══════ *@
<g class="scada-equipment" @onclick="@(() => ToggleAsync(ParamBlowerEnable))" style="cursor:pointer;">
<rect x="@srcTankX" y="@srcTankY" width="@tankW" height="@tankH" rx="@tankShellR" fill="url(#scada-tank-shell)" stroke="#555" stroke-width="1.5" />
@if (sourceFillRatio.HasValue && srcFillH > 0)
{
<rect x="@(srcTankX + 2)" y="@(srcTankBotY - srcFillH)" width="@(tankW - 4)" height="@srcFillH" fill="url(#scada-water-fill)" clip-path="url(#src-tank-clip)" opacity="0.85" />
<line x1="@(srcTankX + 6)" y1="@(srcTankBotY - srcFillH + 2)" x2="@(srcTankX + tankW - 6)" y2="@(srcTankBotY - srcFillH + 2)" stroke="rgba(255,255,255,0.4)" stroke-width="1" />
}
<line x1="@srcTankX" y1="@srcTankY" x2="@(srcTankX + tankW)" y2="@srcTankY" stroke="#555" stroke-width="2" />
<line x1="@(srcTankX + 6)" y1="@(srcTankY + 4)" x2="@(srcTankX + 6)" y2="@(srcTankBotY - 4)" stroke="rgba(255,255,255,0.5)" stroke-width="1.5" />
<line x1="@(srcTankX - 8)" y1="@srcTankY" x2="@(srcTankX - 3)" y2="@srcTankY" stroke="#333" stroke-width="1" />
<text x="@(srcTankX - 12)" y="@(srcTankY + 3)" text-anchor="end" style="fill:#000;font:600 7px 'Segoe UI',sans-serif;">HH</text>
<line x1="@(srcTankX - 8)" y1="@(srcTankY + tankH * 0.25)" x2="@(srcTankX - 3)" y2="@(srcTankY + tankH * 0.25)" stroke="#333" stroke-width="1" />
<text x="@(srcTankX - 12)" y="@(srcTankY + tankH * 0.25 + 3)" text-anchor="end" style="fill:#000;font:600 7px 'Segoe UI',sans-serif;">H</text>
<line x1="@(srcTankX - 8)" y1="@(srcTankY + tankH * 0.75)" x2="@(srcTankX - 3)" y2="@(srcTankY + tankH * 0.75)" stroke="#333" stroke-width="1" />
<text x="@(srcTankX - 12)" y="@(srcTankY + tankH * 0.75 + 3)" text-anchor="end" style="fill:#000;font:600 7px 'Segoe UI',sans-serif;">L</text>
<line x1="@(srcTankX - 8)" y1="@srcTankBotY" x2="@(srcTankX - 3)" y2="@srcTankBotY" stroke="#333" stroke-width="1" />
<text x="@(srcTankX - 12)" y="@(srcTankBotY + 3)" text-anchor="end" style="fill:#000;font:600 7px 'Segoe UI',sans-serif;">LL</text>
@if (sourceAlert)
{
<circle cx="@(srcTankX - 16)" cy="@(srcTankBotY - 8)" r="5" fill="#c62828" stroke="#fff" stroke-width="0.5">
<animate attributeName="opacity" values="1;0.3;1" dur="1s" repeatCount="indefinite" />
</circle>
}
<text x="@srcTankCX" y="@(srcTankBotY + 18)" text-anchor="middle" style="fill:#000;font:bold 10px 'Segoe UI',sans-serif;">TK-301</text>
<text x="@srcTankCX" y="@(srcTankBotY + 30)" text-anchor="middle" style="fill:#333;font:400 9px 'Segoe UI',sans-serif;">Source Tank</text>
</g>

@* ═══════ DESTINATION TANK TK-302 ═══════ *@
<g class="scada-equipment">
<rect x="@dstTankX" y="@dstTankY" width="@tankW" height="@tankH" rx="@tankShellR" fill="url(#scada-tank-shell)" stroke="#555" stroke-width="1.5" />
@if (destinationFillRatio.HasValue && dstFillH > 0)
{
<rect x="@(dstTankX + 2)" y="@(dstTankBotY - dstFillH)" width="@(tankW - 4)" height="@dstFillH" fill="url(#scada-water-fill)" clip-path="url(#dst-tank-clip)" opacity="0.85" />
<line x1="@(dstTankX + 6)" y1="@(dstTankBotY - dstFillH + 2)" x2="@(dstTankX + tankW - 6)" y2="@(dstTankBotY - dstFillH + 2)" stroke="rgba(255,255,255,0.4)" stroke-width="1" />
}
<line x1="@dstTankX" y1="@dstTankY" x2="@(dstTankX + tankW)" y2="@dstTankY" stroke="#555" stroke-width="2" />
<line x1="@(dstTankX + 6)" y1="@(dstTankY + 4)" x2="@(dstTankX + 6)" y2="@(dstTankBotY - 4)" stroke="rgba(255,255,255,0.5)" stroke-width="1.5" />
<line x1="@(dstTankX + tankW + 3)" y1="@dstTankY" x2="@(dstTankX + tankW + 8)" y2="@dstTankY" stroke="#333" stroke-width="1" />
<text x="@(dstTankX + tankW + 12)" y="@(dstTankY + 3)" style="fill:#000;font:600 7px 'Segoe UI',sans-serif;">HH</text>
<line x1="@(dstTankX + tankW + 3)" y1="@(dstTankY + tankH * 0.25)" x2="@(dstTankX + tankW + 8)" y2="@(dstTankY + tankH * 0.25)" stroke="#333" stroke-width="1" />
<text x="@(dstTankX + tankW + 12)" y="@(dstTankY + tankH * 0.25 + 3)" style="fill:#000;font:600 7px 'Segoe UI',sans-serif;">H</text>
<line x1="@(dstTankX + tankW + 3)" y1="@(dstTankY + tankH * 0.75)" x2="@(dstTankX + tankW + 8)" y2="@(dstTankY + tankH * 0.75)" stroke="#333" stroke-width="1" />
<text x="@(dstTankX + tankW + 12)" y="@(dstTankY + tankH * 0.75 + 3)" style="fill:#000;font:600 7px 'Segoe UI',sans-serif;">L</text>
<line x1="@(dstTankX + tankW + 3)" y1="@dstTankBotY" x2="@(dstTankX + tankW + 8)" y2="@dstTankBotY" stroke="#333" stroke-width="1" />
<text x="@(dstTankX + tankW + 12)" y="@(dstTankBotY + 3)" style="fill:#000;font:600 7px 'Segoe UI',sans-serif;">LL</text>
@if (destinationAlert)
{
<circle cx="@(dstTankX + tankW + 16)" cy="@(dstTankY + 8)" r="5" fill="#c62828" stroke="#fff" stroke-width="0.5">
<animate attributeName="opacity" values="1;0.3;1" dur="1s" repeatCount="indefinite" />
</circle>
}
<text x="@dstTankCX" y="@(dstTankBotY + 18)" text-anchor="middle" style="fill:#000;font:bold 10px 'Segoe UI',sans-serif;">TK-302</text>
<text x="@dstTankCX" y="@(dstTankBotY + 30)" text-anchor="middle" style="fill:#333;font:400 9px 'Segoe UI',sans-serif;">Destination Tank</text>
</g>

@* ═══════ BLOWER P-301 ═══════ *@
<g class="scada-equipment" @onclick="@(() => ToggleAsync(ParamBlowerEnable))" style="cursor:pointer;">
<circle cx="@blowerCX" cy="@blowerCY" r="@blowerR" fill="#e8e8e8" stroke="#555" stroke-width="1.5" />
<line x1="@(blowerCX - 12)" y1="@(blowerCY - 8)" x2="@(blowerCX + 4)" y2="@(blowerCY + 14)" stroke="#555" stroke-width="1.5" />
<line x1="@(blowerCX + 12)" y1="@(blowerCY - 8)" x2="@(blowerCX - 4)" y2="@(blowerCY + 14)" stroke="#555" stroke-width="1.5" />
<line x1="@blowerCX" y1="@(blowerCY - blowerR)" x2="@blowerCX" y2="@(blowerCY - blowerR - 12)" stroke="@pipeColor" stroke-width="@pipeWidth" />
<rect x="@blowerMotorX" y="@blowerMotorY" width="32" height="32" rx="3" fill="@(BlowerRunning ? "url(#scada-motor-running)" : "url(#scada-motor-stopped)")" stroke="#333" stroke-width="1" />
<text x="@(blowerMotorX + 16)" y="@(blowerMotorY + 20)" text-anchor="middle" style="fill:#fff;font:bold 10px 'Segoe UI',sans-serif;">M</text>
<line x1="@(blowerCX + blowerR)" y1="@blowerCY" x2="@blowerMotorX" y2="@(blowerMotorY + 16)" stroke="#555" stroke-width="1.5" />
<text x="@blowerCX" y="@(blowerCY + blowerR + 18)" text-anchor="middle" style="fill:#000;font:bold 10px 'Segoe UI',sans-serif;">P-301</text>
<text x="@blowerCX" y="@(blowerCY + blowerR + 30)" text-anchor="middle" style="fill:#333;font:400 9px 'Segoe UI',sans-serif;">Blower</text>
<text x="@(blowerMotorX + 16)" y="@(blowerMotorY - 4)" text-anchor="middle" style="fill:#000;font:bold 8px 'Segoe UI',sans-serif;">M-301</text>
</g>

@* ═══════ ROTARY AIRLOCK RV-301 ═══════ *@
<g class="scada-equipment" @onclick="@(() => ToggleAsync(ParamAirlockEnable))" style="cursor:pointer;">
<rect x="@airlockX" y="@(airlockY - airlockH / 2)" width="@airlockW" height="@airlockH" rx="4" fill="#e8e8e8" stroke="#555" stroke-width="1.5" />
<circle cx="@(airlockX + airlockW / 2)" cy="@airlockY" r="10" fill="none" stroke="#555" stroke-width="1" />
<line x1="@(airlockX + airlockW / 2)" y1="@(airlockY - 10)" x2="@(airlockX + airlockW / 2)" y2="@(airlockY + 10)" stroke="#555" stroke-width="1" />
<line x1="@(airlockX + airlockW / 2 - 7)" y1="@(airlockY - 7)" x2="@(airlockX + airlockW / 2 + 7)" y2="@(airlockY + 7)" stroke="#555" stroke-width="1" />
<line x1="@(airlockX + airlockW / 2 + 7)" y1="@(airlockY - 7)" x2="@(airlockX + airlockW / 2 - 7)" y2="@(airlockY + 7)" stroke="#555" stroke-width="1" />
<rect x="@airlockMotorX" y="@airlockMotorY" width="28" height="24" rx="3" fill="@(AirlockRunning ? "url(#scada-motor-running)" : "url(#scada-motor-stopped)")" stroke="#333" stroke-width="1" />
<text x="@(airlockMotorX + 14)" y="@(airlockMotorY + 16)" text-anchor="middle" style="fill:#fff;font:bold 9px 'Segoe UI',sans-serif;">M</text>
<line x1="@(airlockX + airlockW)" y1="@airlockY" x2="@airlockMotorX" y2="@(airlockMotorY + 12)" stroke="#555" stroke-width="1.5" />
<text x="@(airlockX + airlockW / 2)" y="@(airlockY + airlockH / 2 + 18)" text-anchor="middle" style="fill:#000;font:bold 10px 'Segoe UI',sans-serif;">RV-301</text>
<text x="@(airlockX + airlockW / 2)" y="@(airlockY + airlockH / 2 + 30)" text-anchor="middle" style="fill:#333;font:400 9px 'Segoe UI',sans-serif;">Rotary Airlock</text>
<text x="@(airlockMotorX + 14)" y="@(airlockMotorY - 4)" text-anchor="middle" style="fill:#000;font:bold 8px 'Segoe UI',sans-serif;">M-302</text>
</g>

@* ═══════ PIPING ═══════ *@
<g class="scada-piping">
@* Material feed: source tank → drop → horizontal → into airlock top *@
<line x1="@srcTankCX" y1="@srcTankBotY" x2="@srcTankCX" y2="@materialRouteY" stroke="@pipeColor" stroke-width="@pipeWidth" />
<line x1="@srcTankCX" y1="@materialRouteY" x2="@airlockCX" y2="@materialRouteY" stroke="@pipeColor" stroke-width="@pipeWidth" />
<line x1="@airlockCX" y1="@materialRouteY" x2="@airlockCX" y2="@(airlockY - airlockH / 2)" stroke="@pipeColor" stroke-width="@pipeWidth" />
@* Air line: blower → airlock left side *@
<line x1="@(blowerCX + blowerR)" y1="@blowerCY" x2="@airlockX" y2="@airlockY" stroke="@pipeColor" stroke-width="@pipeWidth" />
@* Blowline: airlock discharge → flow meter → dest tank *@
<line x1="@(airlockX + airlockW)" y1="@airlockY" x2="@fmX" y2="@airlockY" stroke="@pipeColor" stroke-width="@pipeWidth" />
<line x1="@fmX" y1="@airlockY" x2="@fmX" y2="@(dstTankBotY + 10)" stroke="@pipeColor" stroke-width="@pipeWidth" />
<line x1="@fmX" y1="@(dstTankBotY + 10)" x2="@dstTankCX" y2="@(dstTankBotY + 10)" stroke="@pipeColor" stroke-width="@pipeWidth" />
<line x1="@dstTankCX" y1="@(dstTankBotY + 10)" x2="@dstTankCX" y2="@dstTankBotY" stroke="@pipeColor" stroke-width="@pipeWidth" />
@if (TransferPermitted)
{
@* Material flow arrows *@
<polygon points="@(srcTankCX - 4),@(srcTankBotY + 30) @(srcTankCX + 4),@(srcTankBotY + 30) @(srcTankCX),@(srcTankBotY + 38)" fill="@pipeColor" />
<polygon points="@(airlockCX - 30),@(materialRouteY - 4) @(airlockCX - 30),@(materialRouteY + 4) @(airlockCX - 22),@materialRouteY" fill="@pipeColor" />
@* Air flow arrow (blower → airlock) *@
<polygon points="@(airlockX - 16),@(airlockY - 4) @(airlockX - 16),@(airlockY + 4) @(airlockX - 8),@airlockY" fill="@pipeColor" />
@* Discharge flow arrow (into dest tank) *@
<polygon points="@(dstTankCX - 4),@(dstTankBotY + 6) @(dstTankCX + 4),@(dstTankBotY + 6) @(dstTankCX),@(dstTankBotY - 2)" fill="@pipeColor" />
}
</g>

@* ═══════ FLOW METER FM-301 ═══════ *@
<g>
<rect x="@(fmX - 16)" y="@(fmY - 8)" width="32" height="20" rx="2" fill="#e8e8e8" stroke="#555" stroke-width="1" />
<circle cx="@fmX" cy="@(fmY + 2)" r="7" fill="none" stroke="#555" stroke-width="1" />
<text x="@fmX" y="@(fmY + 5)" text-anchor="middle" style="fill:#555;font:bold 8px 'Segoe UI',sans-serif;">F</text>
<text x="@fmX" y="@(fmY + 28)" text-anchor="middle" style="fill:#000;font:bold 9px 'Segoe UI',sans-serif;">FM-301</text>
</g>

@* ═══════ READOUT BOXES ═══════ *@
<g style="cursor:pointer;" @onclick="() => OpenTrend(TrendKey.SourceTankWeightLb)">
<rect x="@readout1X" y="@readout1Y" width="90" height="22" rx="2" fill="#1a1a1a" stroke="#555" stroke-width="0.8" />
<text x="@(readout1X + 45)" y="@(readout1Y + 15)" text-anchor="middle" style="fill:#00e676;font:bold 12px 'Consolas',monospace;">@SourceTankWeight.ToString("0", System.Globalization.CultureInfo.InvariantCulture) lb</text>
<text x="@(readout1X + 45)" y="@(readout1Y - 4)" text-anchor="middle" style="fill:#000;font:600 8px 'Segoe UI',sans-serif;">WT-301</text>
</g>
<g style="cursor:pointer;" @onclick="() => OpenTrend(TrendKey.DestinationTankWeightLb)">
<rect x="@(dstTankX + tankW + 30)" y="@(dstTankY + 40)" width="90" height="22" rx="2" fill="#1a1a1a" stroke="#555" stroke-width="0.8" />
<text x="@(dstTankX + tankW + 75)" y="@(dstTankY + 55)" text-anchor="middle" style="fill:#00e676;font:bold 12px 'Consolas',monospace;">@DestinationTankWeight.ToString("0", System.Globalization.CultureInfo.InvariantCulture) lb</text>
<text x="@(dstTankX + tankW + 75)" y="@(dstTankY + 36)" text-anchor="middle" style="fill:#000;font:600 8px 'Segoe UI',sans-serif;">WT-302</text>
</g>
<g style="cursor:pointer;" @onclick="() => OpenTrend(TrendKey.BlowlinePressurePsi)">
<rect x="@readout2X" y="@readout2Y" width="90" height="22" rx="2" fill="#1a1a1a" stroke="#555" stroke-width="0.8" />
<text x="@(readout2X + 45)" y="@(readout2Y + 15)" text-anchor="middle" style="fill:#00e676;font:bold 12px 'Consolas',monospace;">@BlowlinePressurePsi.ToString("0.00", System.Globalization.CultureInfo.InvariantCulture) psi</text>
<text x="@(readout2X + 45)" y="@(readout2Y - 4)" text-anchor="middle" style="fill:#000;font:600 8px 'Segoe UI',sans-serif;">PT-301</text>
</g>
<g style="cursor:pointer;" @onclick="() => OpenTrend(TrendKey.TransferRateLbPerSec)">
<rect x="@(fmX - 45)" y="@(fmY + 36)" width="90" height="22" rx="2" fill="#1a1a1a" stroke="#555" stroke-width="0.8" />
<text x="@fmX" y="@(fmY + 51)" text-anchor="middle" style="fill:#00e676;font:bold 12px 'Consolas',monospace;">@TransferRateLbPerSec.ToString("0.00", System.Globalization.CultureInfo.InvariantCulture) lb/s</text>
<text x="@fmX" y="@(fmY + 32)" text-anchor="middle" style="fill:#000;font:600 8px 'Segoe UI',sans-serif;">FT-301</text>
</g>
<g style="cursor:pointer;" @onclick="() => OpenTrend(TrendKey.BlowerMotorPercentFla)">
<rect x="@(blowerMotorX - 10)" y="@(blowerMotorY + 38)" width="56" height="22" rx="2" fill="#1a1a1a" stroke="#555" stroke-width="0.8" />
<text x="@(blowerMotorX + 18)" y="@(blowerMotorY + 53)" text-anchor="middle" style="fill:@(BlowerMotorPercentFla > 85 ? "#ff5252" : "#00e676");font:bold 11px 'Consolas',monospace;">@BlowerMotorPercentFla.ToString("0.0", System.Globalization.CultureInfo.InvariantCulture)%</text>
<text x="@(blowerMotorX + 18)" y="@(blowerMotorY + 34)" text-anchor="middle" style="fill:#000;font:600 8px 'Segoe UI',sans-serif;">M-301</text>
</g>
<g style="cursor:pointer;" @onclick="() => OpenTrend(TrendKey.AirlockSpeedHz)">
<rect x="@(airlockX + airlockW / 2 - 30)" y="@(airlockY - airlockH / 2 - 32)" width="60" height="22" rx="2" fill="#1a1a1a" stroke="#555" stroke-width="0.8" />
<text x="@(airlockX + airlockW / 2)" y="@(airlockY - airlockH / 2 - 17)" text-anchor="middle" style="fill:#00e676;font:bold 11px 'Consolas',monospace;">@AirlockSpeedHz.ToString("0.0", System.Globalization.CultureInfo.InvariantCulture) Hz</text>
<text x="@(airlockX + airlockW / 2)" y="@(airlockY - airlockH / 2 - 36)" text-anchor="middle" style="fill:#000;font:600 8px 'Segoe UI',sans-serif;">SI-301</text>
</g>
<g style="cursor:pointer;" @onclick="OpenSetpointModal">
<rect x="@(blowerCX - blowerR - 60)" y="@(blowerCY - blowerR - 32)" width="60" height="22" rx="2" fill="#1a1a1a" stroke="#555" stroke-width="0.8" />
<text x="@(blowerCX - blowerR - 30)" y="@(blowerCY - blowerR - 17)" text-anchor="middle" style="fill:#ffab40;font:bold 11px 'Consolas',monospace;">@BlowlinePressureCmdPsi.ToString("0.0", System.Globalization.CultureInfo.InvariantCulture) psi</text>
<text x="@(blowerCX - blowerR - 30)" y="@(blowerCY - blowerR - 36)" text-anchor="middle" style="fill:#000;font:600 8px 'Segoe UI',sans-serif;">SP-301</text>
</g>

@* ═══════ STATUS BANNER ═══════ *@
<rect x="@(processW / 2 - 130)" y="@(processTop + processH - 42)" width="260" height="26" rx="3" fill="@(ActiveFault ? "#c62828" : "#2e7d32")" stroke="@(ActiveFault ? "#7f1010" : "#1b5e20")" stroke-width="1" />
<text x="@(processW / 2)" y="@(processTop + processH - 25)" text-anchor="middle" style="fill:#fff;font:bold 11px 'Segoe UI',sans-serif;letter-spacing:0.08em;">@(ActiveFault ? FaultLabel.ToUpperInvariant() : "TRANSFER PERMITTED — ROUTE ACTIVE")</text>

@* ═══════ SIDEBAR ═══════ *@
<rect x="@sidebarX" y="@(alarmBannerH + tabBarH)" width="@sidebarW" height="@(scadaH - alarmBannerH - tabBarH)" fill="#e8e8e8" stroke="#aaa" stroke-width="0.5" />
<g>
<rect x="@(sidebarX + 8)" y="@(alarmBannerH + tabBarH + 8)" width="@(sidebarW - 16)" height="20" rx="2" fill="#fff" stroke="#bbb" stroke-width="0.5" />
<text x="@(sidebarX + 20)" y="@(alarmBannerH + tabBarH + 22)" style="fill:#0055a0;font:600 10px 'Segoe UI',sans-serif;">🏠 Home Page</text>
</g>
<text x="@(sidebarX + 12)" y="@(alarmBannerH + tabBarH + 48)" style="fill:#000;font:bold 9px 'Segoe UI',sans-serif;">☐ Pages</text>
@{
var pageItems = new[] { ("Tank Transfer C3", true), ("Blower System", false), ("Airlock Control", false), ("Pressure Loop", false), ("Parameter Page 1", false), ("Parameter Page 2", false) };
var pageY = alarmBannerH + tabBarH + 60.0;
}
@foreach (var (pageName, isSelected) in pageItems)
{
var bgColor = isSelected ? "#cce5ff" : "transparent";
